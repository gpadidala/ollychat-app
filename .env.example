# ─────────────────────────────────────────────────────────────
# O11yBot — configuration
# Copy to .env.  Every value has a sensible default; only set
# what you actually want to override.
#
#   cp .env.example .env
#   make up
# ─────────────────────────────────────────────────────────────

# ─── Host port bindings (keep defaults unless they collide) ──
GRAFANA_EXTERNAL_PORT=3002
ORCHESTRATOR_PORT=8000
MCP_PORT=8765
OLLAMA_PORT=11434
OTEL_GRPC_PORT=4327
OTEL_HTTP_PORT=4328

# ─── Grafana admin (the bundled dev Grafana on :3002) ────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─── Target Grafana — where the MCP layer sends tool calls ──
# Inside the compose network, the bundled Grafana answers at
# http://grafana:3000.  Override if you're pointing O11yBot at
# your own existing Grafana (OSS or Enterprise).
GRAFANA_URL=http://grafana:3000

# ─── Role-based service-account tokens ──────────────────────
# Create three SA tokens in the target Grafana:
#   Grafana → Administration → Users and access → Service accounts
# Set them here for real RBAC enforcement.  For a demo, set just
# GRAFANA_TOKEN and it's used for every role.
GRAFANA_VIEWER_TOKEN=
GRAFANA_EDITOR_TOKEN=
GRAFANA_ADMIN_TOKEN=
GRAFANA_TOKEN=

# Set to "false" only if your Grafana uses a self-signed cert.
GRAFANA_TLS_VERIFY=true

# ─── LLM selection (orchestrator) ───────────────────────────
# Default is the local Ollama model (cost $0).  Swap to any of
# the providers below by changing the model name.
OLLYCHAT_DEFAULT_MODEL=qwen2.5:0.5b
OLLYCHAT_DEFAULT_MAX_TOKENS=4096
OLLYCHAT_DEFAULT_TEMPERATURE=0.2
OLLYCHAT_MAX_TOOL_LOOP_ITERATIONS=8

# Cloud LLM keys (optional — only set the one you'll use)
OLLYCHAT_ANTHROPIC_API_KEY=
OLLYCHAT_OPENAI_API_KEY=
OLLYCHAT_GOOGLE_API_KEY=
OLLYCHAT_MISTRAL_API_KEY=
OLLYCHAT_GROQ_API_KEY=
OLLYCHAT_AZURE_OPENAI_API_KEY=
OLLYCHAT_AZURE_OPENAI_ENDPOINT=

# ─── PII scanner ────────────────────────────────────────────
OLLYCHAT_PII_ENABLED=true
OLLYCHAT_PII_MODE=redact   # redact | block | log

# ─── Self-owned MCP server (auto-registered on startup) ─────
OLLYCHAT_BIFROST_URL=http://ollychat-mcp:8765

# ─── OTEL / logging ─────────────────────────────────────────
OLLYCHAT_OTEL_EXPORTER_ENDPOINT=otel-collector:4317
OLLYCHAT_OTEL_SERVICE_NAME=ollychat-orchestrator
OLLYCHAT_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# Corporate laptop build-time overrides (optional)
# ─────────────────────────────────────────────────────────────
# Needed only if your network intercepts TLS or blocks pypi.org.
# Uncomment + fill before `make up` — compose picks them up
# automatically as Docker build args for every service.
#
# HTTP_PROXY=http://proxy.corp:3128
# HTTPS_PROXY=http://proxy.corp:3128
# NO_PROXY=localhost,127.0.0.1,.corp
# PIP_INDEX_URL=https://artifactory.corp/api/pypi/pypi/simple
# PIP_TRUSTED_HOST=artifactory.corp
# CA_CERT_PATH=corp-ca.crt   # drop your CA file at repo root and point at it
