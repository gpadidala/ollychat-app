# ─────────────────────────────────────────────────────────
# O11yBot Configuration
# Copy to .env and fill in your values.
#
# The plugin is self-contained — point GRAFANA_URL + tokens at
# any Grafana instance and `docker compose up` boots the full stack.
# ─────────────────────────────────────────────────────────

# --- Target Grafana instance (the plugin manages dashboards/alerts here) ---
GRAFANA_URL=http://host.docker.internal:3000

# Role-based service-account tokens (Grafana → Admin → Service accounts).
# Set all three for real RBAC. For a quick demo, set only GRAFANA_TOKEN.
GRAFANA_VIEWER_TOKEN=
GRAFANA_EDITOR_TOKEN=
GRAFANA_ADMIN_TOKEN=
GRAFANA_TOKEN=
GRAFANA_TLS_VERIFY=true

# --- LLM Provider API Keys ---
OLLYCHAT_ANTHROPIC_API_KEY=sk-ant-...
OLLYCHAT_OPENAI_API_KEY=sk-...
OLLYCHAT_GOOGLE_API_KEY=
OLLYCHAT_MISTRAL_API_KEY=
OLLYCHAT_GROQ_API_KEY=

# --- Azure OpenAI (optional) ---
OLLYCHAT_AZURE_OPENAI_API_KEY=
OLLYCHAT_AZURE_OPENAI_ENDPOINT=

# --- Ollama (local LLM) ---
OLLYCHAT_OLLAMA_BASE_URL=http://ollama:11434

# --- Default LLM ---
OLLYCHAT_DEFAULT_MODEL=claude-sonnet-4-6
OLLYCHAT_DEFAULT_MAX_TOKENS=4096
OLLYCHAT_DEFAULT_TEMPERATURE=0.2
OLLYCHAT_MAX_TOOL_LOOP_ITERATIONS=8

# --- PII Detection ---
OLLYCHAT_PII_ENABLED=true
OLLYCHAT_PII_MODE=redact

# --- O11yBot MCP Server (owned by this repo, not an external dep) ---
# When running via docker compose, the orchestrator resolves it by service name.
OLLYCHAT_BIFROST_URL=http://ollychat-mcp:8765

# --- OTEL ---
OLLYCHAT_OTEL_EXPORTER_ENDPOINT=otel-collector:4317
OLLYCHAT_OTEL_SERVICE_NAME=ollychat-orchestrator

# --- Logging ---
OLLYCHAT_LOG_LEVEL=info
