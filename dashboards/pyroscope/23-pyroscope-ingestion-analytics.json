  "uid": "pyroscope-ingestion-analytics",
  "title": "Pyroscope — Profile Ingestion & Storage Analytics",
  "description": "Advanced Pyroscope continuous profiling ingestion analytics. Track profile volume by service, ingestion throughput, storage growth, and identify top CPU/memory consumers.",
  "tags": [
    "pyroscope",
    "ingestion",
    "profiles",
    "analytics",
    "advanced",
    "continuous-profiling"
  ],
  "editable": true,
  "graphTooltip": 2,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "timezone": "utc",
  "weekStart": "",
