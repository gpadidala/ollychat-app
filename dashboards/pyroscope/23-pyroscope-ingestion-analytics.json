  "timepicker": {
    "refresh_intervals": [
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "query": "label_values(pyroscope_build_info, cluster)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "options": [],
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "query": "label_values(pyroscope_build_info{cluster=~\"$cluster\"}, namespace)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "options": [],
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "query": "label_values(pyroscope_distributor_received_samples_total{cluster=~\"$cluster\"}, tenant)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "options": [],
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      },
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "query": "label_values(pyroscope_distributor_received_samples_total{cluster=~\"$cluster\"}, service_name)",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "current": {},
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "options": [],
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Profiling Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Profiles Ingested/sec",
      "description": "Total rate of profile samples ingested across all Pyroscope distributors. Indicates the overall profiling write throughput entering the system.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pyroscope_distributor_received_samples_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Profiles/sec",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#6C63FF",
                "value": null
              }
            ]
          },
          "color": {
            "fixedColor": "#6C63FF",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Bytes Received/sec",
      "description": "Rate of compressed profile bytes received by the distributors. Reflects the network bandwidth consumed by profile ingestion.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pyroscope_distributor_received_compressed_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Bytes/sec",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#4FC3F7",
                "value": null
              }
            ]
          },
          "color": {
            "fixedColor": "#4FC3F7",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Series",
      "description": "Total number of active profiling series across all ingesters. High cardinality may indicate excessive label combinations or unconstrained service instrumentation.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pyroscope_ingester_active_series{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "Active Series",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00C48C",
                "value": null
              }
            ]
          },
          "color": {
            "fixedColor": "#00C48C",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Write Latency P95",
      "description": "95th percentile latency for profile push/ingest requests. Sustained values above 500ms indicate distributor or ingester saturation.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(pyroscope_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\", route=~\".*push.*|.*ingest.*\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Ingestion Errors",
      "description": "Rate of failed push/ingest requests (HTTP 4xx and 5xx). Non-zero values indicate client-side issues (4xx) or server-side failures (5xx) in the ingestion pipeline.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pyroscope_request_duration_seconds_count{cluster=~\"$cluster\", namespace=~\"$namespace\", route=~\".*push.*|.*ingest.*\", status_code=~\"[45]..\"}[$__rate_interval])) or vector(0)",
          "legendFormat": "Errors/sec",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Pyroscope Instances",
      "description": "Total number of Pyroscope component instances currently reporting build info. A drop from the expected count indicates instance failures or incomplete rollouts.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(pyroscope_build_info{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "Instances",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#00C48C",
                "value": null
              }
            ]
          },
          "color": {
            "fixedColor": "#00C48C",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "wideLayout": true,
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Ingestion Throughput",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": [
        {
          "id": 7,
          "type": "timeseries",
          "title": "Profiles Ingested Over Time",
          "description": "Rate of profile samples received by the distributor, broken down by tenant. Reveals which tenants are the heaviest producers and helps identify sudden ingestion spikes.",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 6
          },
          "targets": [
            {
              "refId": "A",
              "expr": "sum by (tenant) (rate(pyroscope_distributor_received_samples_total{cluster=~\"$cluster\", namespace=~\"$namespace\", tenant=~\"$tenant\"}[$__rate_interval]))",
              "legendFormat": "{{tenant}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "lineWidth": 2,
                "fillOpacity": 30,
                "gradientMode": "none",
                "spanNulls": false,
                "showPoints": "never",
                "pointSize": 5,
                "stacking": {
                  "mode": "normal",
                  "group": "A"
                },
                "axisPlacement": "auto",
                "axisLabel": "",
                "scaleDistribution": {
                  "type": "linear"
                },
                "thresholdsStyle": {
                  "mode": "off"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  }
                ]
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "showValues": true,
              "calcs": [
                "mean",
                "max",
                "lastNotNull"
              ]
            }
          }
        },
        {
          "id": 8,
          "type": "timeseries",
          "title": "Bytes Received Over Time",
          "description": "Rate of compressed bytes received by the distributor, broken down by cluster. Tracks the network and storage bandwidth pressure from profiling data.",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 6
          },
          "targets": [
            {
              "refId": "A",
              "expr": "sum by (cluster) (rate(pyroscope_distributor_received_compressed_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
              "legendFormat": "{{cluster}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "lineWidth": 2,
                "fillOpacity": 20,
                "gradientMode": "none",
                "spanNulls": false,
                "showPoints": "never",
                "pointSize": 5,
                "stacking": {
                  "mode": "none",
                  "group": "A"
                },
                "axisPlacement": "auto",
                "axisLabel": "",
                "scaleDistribution": {
                  "type": "linear"
                },
                "thresholdsStyle": {
                  "mode": "off"
                }
              },
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  }
                ]
              },
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          },
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "showValues": true,
              "calcs": [
                "mean",
                "max",
                "lastNotNull"
              ]
            }
          }
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Top Profile Producers",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "panels": [
        {
          "id": 9,
          "type": "bargauge",
          "title": "Top 10 Services by Profile Volume",
          "description": "The ten services generating the highest rate of profile samples. Use this to identify noisy services that may need sampling adjustment or profile type filtering.",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 15
          },
          "targets": [
            {
              "refId": "A",
              "expr": "topk(10, sum by (service_name) (rate(pyroscope_distributor_received_samples_total{cluster=~\"$cluster\", namespace=~\"$namespace\", service_name=~\"$service\"}[$__rate_interval])))",
              "legendFormat": "{{service_name}}",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "mappings": [],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "blue",
                    "value": null
                  },
                  {
                    "color": "green",
                    "value": 100
                  },
                  {
                    "color": "yellow",
                    "value": 1000
                  },
                  {
                    "color": "orange",
                    "value": 5000
                  },
                  {
                    "color": "red",
                    "value": 10000
                  }
                ]
              },
              "color": {
                "mode": "continuous-BlYlRd"
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ],
              "fields": "",
              "values": false
            },
            "orientation": "horizontal",
            "displayMode": "gradient",
            "showUnfilled": true,
            "minVizWidth": 0,
            "minVizHeight": 10,
            "namePlacement": "auto",
            "valueMode": "color"
          }
        },
        {
          "id": 10,
          "type": "bargauge",
          "title": "Top 10 Tenants by Active Series",
          "description": "The ten tenants with the highest active series count in Pyroscope ingesters. Helps identify tenants driving cardinality growth and potential resource contention.",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 15
          },
          "targets": [
            {
              "refId": "A",
              "expr": "topk(10, sum by (tenant) (pyroscope_ingester_active_series{cluster=~\"$cluster\", namespace=~\"$namespace\", tenant=~\"$tenant\"}))",
              "legendFormat": "{{tenant}}",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {
