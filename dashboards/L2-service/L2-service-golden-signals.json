        "w": 12,
        "x": 12,
        "y": 48
      },
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "$datasource_pyroscope"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "profile",
          "profileTypeId": "memory:alloc_objects:count:space:bytes",
          "labelSelector": "{service_name=\"$service\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    }
