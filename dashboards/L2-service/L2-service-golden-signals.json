  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "description": "Breadcrumb navigation showing hierarchy path and lateral links to L3 deep-dive dashboards.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-size:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;\">\n  <a href=\"/d/l1-application-performance/\" style=\"color:#6E9FFF; text-decoration:none;\">&larr; Back to Applications</a>\n  <span style=\"color:#aaa;\">|</span>\n  <span style=\"color:#ccc;\"><a href=\"/d/l0-executive-command-center/\" style=\"color:#6E9FFF; text-decoration:none;\">L0: Command Center</a> &rarr; <a href=\"/d/l1-application-performance/\" style=\"color:#6E9FFF; text-decoration:none;\">L1: Applications</a> &rarr; <strong style=\"color:#FF9830;\">L2: $service</strong></span>\n  <span style=\"color:#aaa;\">|</span>\n  <a href=\"/d/l3-trace-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Traces]</a>\n  <a href=\"/d/l3-log-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Logs]</a>\n  <a href=\"/d/l3-profile-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Profiles]</a>\n</div>"
      },
      "datasource": {
        "type": "datasource",
        "uid": "grafana"
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Service Health Strip",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "description": "Current HTTP request rate for the selected service. A sudden drop may signal an outage or upstream routing change.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Request Rate",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "description": "Percentage of 5xx responses for the selected service. Values above 1% warrant investigation; above 5% is a critical issue.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"$service\", status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum(rate(http_requests_total{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) * 100",
          "legendFormat": "Error Rate %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "green", "value": 0 },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P50 Latency",
      "description": "Median (50th percentile) request duration for the selected service. Represents the typical user experience.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "P50",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "P95 Latency",
      "description": "95th percentile request duration. Captures the tail latency affecting 5% of users. Above 0.5s indicates degradation.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "P95",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "green", "value": 0 },
              { "color": "#EAB839", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "P99 Latency",
      "description": "99th percentile request duration. Worst-case latency for the vast majority of requests. Above 1s requires attention.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "P99",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "green", "value": 0 },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "SLO Status",
      "description": "Service availability calculated as the ratio of successful requests. Target is 99.9% (three nines). Below 99% triggers a red alert.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - (sum(rate(http_requests_total{job=\"$service\", status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum(rate(http_requests_total{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001))) * 100",
          "legendFormat": "Availability %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "red", "value": 0 },
              { "color": "#EAB839", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Golden Signals Timeseries",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request Rate Over Time",
      "description": "HTTP request rate broken down by handler/endpoint. Identifies traffic patterns and shifts in endpoint popularity.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(http_requests_total{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Rate Over Time",
      "description": "Error percentage by handler over time. Threshold lines at 1% (warning) and 5% (critical) for quick visual assessment.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (handler) (rate(http_requests_total{job=\"$service\", status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum by (handler) (rate(http_requests_total{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) * 100",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "line+area"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(234, 184, 57, 0.1)", "value": 1 },
              { "color": "rgba(242, 73, 92, 0.1)", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "description": "P50, P95, and P99 latency percentiles over time for the selected service. Enables detection of latency regressions and tail latency spikes.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Resource Utilization",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Usage",
      "description": "CPU usage by pod for the selected service. Compare against requests/limits to identify under- or over-provisioning.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$service.*\", cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "cores",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "Working set memory by pod for the selected service. Sustained growth may indicate a memory leak.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$service.*\", cluster=~\"$cluster\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 13,
      "type": "heatmap",
      "title": "Request Latency Heatmap",
      "description": "Heatmap of request latency distribution. Reveals bimodal latency patterns and latency bands that percentile summaries may hide.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 17
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_request_duration_seconds_bucket{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "log",
              "log": 2
            }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "unit": "s"
        },
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 64,
          "reverse": true
        },
        "cellGap": 1,
        "tooltip": {
          "show": true,
          "yHistogram": true
        },
        "showValue": "never"
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Traces \u2014 Tempo",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "panels": []
    },
    {
      "id": 14,
      "type": "table",
      "title": "Trace Search \u2014 Top Endpoints by Avg Duration",
      "description": "Top 20 endpoints by average response time sourced from Prometheus histogram data. Click an endpoint to drill into its traces in the L3 Trace Explorer.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(20, sum by (handler) (rate(http_request_duration_seconds_sum{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / sum by (handler) (rate(http_request_duration_seconds_count{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "refId": "B",
          "expr": "sum by (handler) (rate(http_requests_total{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "View traces for this endpoint in L3 Trace Explorer",
              "url": "/d/l3-trace-explorer/l3-trace-explorer?var-service=$service&var-endpoint=${__data.fields.handler}&from=${__from}&to=${__to}",
              "targetBlank": true
            }
          ]
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "handler" },
            "properties": [
              { "id": "displayName", "value": "Endpoint" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "Avg Duration" },
              { "id": "unit", "value": "s" },
              { "id": "decimals", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "Throughput" },
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Avg Duration",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {},
            "renameByName": {}
          }
        }
      ]
    },
    {
      "id": 104,
      "type": "row",
      "title": "Logs \u2014 Loki",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "panels": []
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Log Volume by Level",
      "description": "Log volume over time grouped by severity level. A spike in error/warn logs often correlates with service health degradation.",
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 16,
      "type": "logs",
      "title": "Error / Warning Logs",
      "description": "Live error and warning log stream for the selected service. TraceIDs are extracted for correlation with Tempo traces.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 39
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt | level =~ \"error|warn\""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "View trace in Tempo",
              "url": "/explore?orgId=1&left=%7B%22datasource%22:%22$datasource_tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22query%22:%22${__data.fields.traceID}%22,%22queryType%22:%22traceql%22%7D%5D%7D",
              "targetBlank": true,
              "internal": {
                "datasourceUid": "$datasource_tempo",
                "datasourceName": "Tempo",
                "query": {
                  "query": "${__data.fields.traceID}",
                  "queryType": "traceql"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 105,
      "type": "row",
      "title": "Profiling \u2014 Pyroscope",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 47
      },
      "panels": []
