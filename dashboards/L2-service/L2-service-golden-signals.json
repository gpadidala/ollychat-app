  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "enable": true,
        "expr": "changes(process_start_time_seconds{job=\"$service\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m]) > 0",
        "hide": false,
        "iconColor": "#FFA500",
        "name": "Service Restarts",
        "step": "60s",
        "tagKeys": "cluster,namespace",
        "titleFormat": "Restart: {{pod}}",
        "type": "tags"
      }
    ]
  },
  "description": "Team Lead / SRE service-level dashboard with RED metrics, resource utilization, traces, logs, and profiling for a selected service.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
