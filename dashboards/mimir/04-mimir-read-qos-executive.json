          "editorMode": "code",
          "expr": "sum(rate(cortex_query_frontend_enqueue_duration_seconds_bucket{cluster=~\"$cluster\", le=\"0.5\"}[30m])) / sum(rate(cortex_query_frontend_enqueue_duration_seconds_bucket{cluster=~\"$cluster\", le=\"+Inf\"}[30m])) * 100",
