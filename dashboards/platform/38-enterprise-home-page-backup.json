      "description": "Grafana UI & API availability — percentage of requests returning non-5xx responses.",
      "gridPos": { "x": 0, "y": 11, "w": 5, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - (\n  sum(rate(grafana_http_request_duration_seconds_count{status_code=~\"5..\", cluster=~\"$cluster\"}[$__rate_interval]))\n  / (sum(rate(grafana_http_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) + 0.001)\n)) * 100",
          "legendFormat": "Grafana"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
