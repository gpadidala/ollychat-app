{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Enterprise Observability Platform home page. The single starting point for all users — executives, SREs, developers, and platform engineers.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 0,
      "title": "Header",
      "type": "text",
      "description": "Enterprise observability platform branding header with live status indicator.",
      "transparent": true,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex; align-items:center; justify-content:space-between; padding:12px 20px; background:linear-gradient(135deg, rgba(50,116,217,0.08) 0%, rgba(11,12,14,0) 100%); border-bottom:2px solid #3274D9; border-radius:4px;\">\n  <div>\n    <h1 style=\"margin:0; font-size:28px; font-weight:700; color:#E0E0E0; letter-spacing:1px;\">OBSERVABILITY PLATFORM</h1>\n    <p style=\"margin:4px 0 0; font-size:13px; color:#8E8EA0; letter-spacing:0.5px;\">Powered by Grafana &bull; Loki &bull; Tempo &bull; Mimir &bull; Pyroscope</p>\n  </div>\n  <div style=\"display:flex; gap:20px; align-items:center;\">\n    <div style=\"padding:6px 16px; border-radius:16px; background:rgba(115,191,105,0.1); border:1px solid rgba(115,191,105,0.3);\">\n      <span style=\"font-size:13px; color:#73BF69; font-weight:500;\">&#x25CF; ALL SYSTEMS OPERATIONAL</span>\n    </div>\n    <div style=\"text-align:right;\">\n      <span style=\"font-size:11px; color:#6C7080; text-transform:uppercase; letter-spacing:1px;\">LIVE</span><br/>\n      <span style=\"font-size:13px; color:#5794F2;\">Auto-Refresh 1m</span>\n    </div>\n  </div>\n</div>"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 1,
      "title": "Search & Quick Actions",
      "type": "text",
      "description": "Global search bar and quick-access navigation shortcuts for common workflows.",
      "transparent": true,
      "gridPos": { "x": 0, "y": 3, "w": 24, "h": 4 },
      "options": {
        "mode": "html",
        "content": "<div style=\"text-align:center; padding:16px 0 8px;\">\n  <div style=\"display:inline-block; background:#181b1f; border:1px solid #2a2d35; border-radius:8px; padding:12px 32px; width:60%; max-width:700px; cursor:pointer; transition:border-color 0.2s;\" onclick=\"document.dispatchEvent(new KeyboardEvent('keydown',{key:'k',ctrlKey:true}))\">\n    <span style=\"font-size:15px; color:#6C7080;\">&#x1F50D; Search dashboards, alerts, services... &nbsp; <kbd style='background:#2a2d35; padding:2px 8px; border-radius:3px; font-size:11px; color:#8E8EA0;'>Ctrl+K</kbd></span>\n  </div>\n  <div style=\"margin-top:16px; display:flex; justify-content:center; gap:12px; flex-wrap:wrap;\">\n    <a href=\"/alerting/list?search=&alertState=firing\" style=\"padding:8px 16px; background:#181b1f; border:1px solid #2a2d35; border-radius:6px; color:#F2495C; text-decoration:none; font-size:12px; font-weight:500;\">&#x1F6A8; Active Alerts</a>\n    <a href=\"/dashboards?starred=true\" style=\"padding:8px 16px; background:#181b1f; border:1px solid #2a2d35; border-radius:6px; color:#FADE2A; text-decoration:none; font-size:12px; font-weight:500;\">&#x2B50; My Dashboards</a>\n    <a href=\"/explore\" style=\"padding:8px 16px; background:#181b1f; border:1px solid #2a2d35; border-radius:6px; color:#5794F2; text-decoration:none; font-size:12px; font-weight:500;\">&#x1F50D; Explore</a>\n    <a href=\"/d/l0-executive-command-center\" style=\"padding:8px 16px; background:#181b1f; border:1px solid #2a2d35; border-radius:6px; color:#B877D9; text-decoration:none; font-size:12px; font-weight:500;\">&#x1F3AF; Command Center</a>\n    <a href=\"/d/user-journey-dashboard\" style=\"padding:8px 16px; background:#181b1f; border:1px solid #2a2d35; border-radius:6px; color:#73BF69; text-decoration:none; font-size:12px; font-weight:500;\">&#x1F464; User Journey</a>\n    <a href=\"/connections/datasources\" style=\"padding:8px 16px; background:#181b1f; border:1px solid #2a2d35; border-radius:6px; color:#8E8EA0; text-decoration:none; font-size:12px; font-weight:500;\">&#x2699; Data Sources</a>\n  </div>\n</div>"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Platform Health",
      "type": "stat",
      "description": "Composite platform availability calculated from non-5xx response ratio across all services.",
      "gridPos": { "x": 0, "y": 7, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(1 - (sum(rate(grafana_http_request_duration_seconds_count{status_code=~\"5..\", cluster=~\"$cluster\"}[$__rate_interval])) / (sum(rate(grafana_http_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) + 0.001))) * 100",
          "legendFormat": "Availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#F2495C" },
              { "value": 95, "color": "#FF9830" },
              { "value": 99, "color": "#73BF69" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "Platform KPI",
          "url": "/d/ultimate-platform-kpi",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Alerts",
      "type": "stat",
      "description": "Count of currently firing alerts across all alerting rules.",
      "gridPos": { "x": 3, "y": 7, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(ALERTS{alertstate=\"firing\", cluster=~\"$cluster\"}) OR vector(0)",
          "legendFormat": "Firing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#73BF69" },
              { "value": 1, "color": "#FF9830" },
              { "value": 5, "color": "#F2495C" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "Active Alerts",
          "url": "/alerting/list?search=&alertState=firing",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 4,
      "title": "SLO Compliance",
      "type": "stat",
      "description": "Average SLO compliance across services based on request success rate and latency targets.",
      "gridPos": { "x": 6, "y": 7, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(\n  (\n    sum(rate(grafana_http_request_duration_seconds_bucket{le=\"0.5\", cluster=~\"$cluster\"}[$__rate_interval]))\n    / (sum(rate(grafana_http_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) + 0.001)\n  ) * 100\n)",
          "legendFormat": "SLO %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#F2495C" },
              { "value": 95, "color": "#FF9830" },
              { "value": 99, "color": "#73BF69" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "SLO Error Budget Burn",
          "url": "/d/slo-error-budget-burn",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Budget",
      "type": "stat",
      "description": "Remaining error budget as a percentage — how much failure allowance remains before SLO breach.",
      "gridPos": { "x": 9, "y": 7, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(\n  1 - (\n    sum(rate(grafana_http_request_duration_seconds_count{status_code=~\"5..\", cluster=~\"$cluster\"}[$__rate_interval]))\n    / (sum(rate(grafana_http_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) * 0.001 + 0.0001)\n  )\n) * 100",
          "legendFormat": "Budget Remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#F2495C" },
              { "value": 20, "color": "#FF9830" },
              { "value": 50, "color": "#73BF69" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "SLA Business Impact",
          "url": "/d/sla-business-impact-report",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 6,
      "title": "Request Rate",
      "type": "stat",
      "description": "Total request throughput across Grafana, Mimir, and Loki services combined.",
      "gridPos": { "x": 13, "y": 7, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(\n  sum(rate(grafana_http_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) or vector(0)\n) + (\n  sum(rate(cortex_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) or vector(0)\n) + (\n  sum(rate(loki_request_duration_seconds_count{cluster=~\"$cluster\"}[$__rate_interval])) or vector(0)\n)",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#5794F2" }
            ]
          },
          "color": { "fixedColor": "#5794F2", "mode": "fixed" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "Cross-Signal Volume",
          "url": "/d/cross-signal-volume-analytics",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 7,
      "title": "P99 Latency",
      "type": "stat",
      "description": "Global 99th percentile request latency across all instrumented services.",
      "gridPos": { "x": 17, "y": 7, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(grafana_http_request_duration_seconds_bucket{cluster=~\"$cluster\"}[$__rate_interval])))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "#73BF69" },
              { "value": 0.2, "color": "#73BF69" },
              { "value": 0.5, "color": "#FF9830" },
              { "value": 1, "color": "#F2495C" }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "Application Performance",
          "url": "/d/l1-application-performance",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 8,
      "title": "Active Users",
      "type": "stat",
      "description": "Number of active users currently logged into the Grafana platform.",
      "gridPos": { "x": 21, "y": 7, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "grafana_stat_active_users",
          "legendFormat": "Users"
