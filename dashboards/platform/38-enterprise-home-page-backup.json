      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "User Activity Analytics",
          "url": "/d/grafana-user-activity-analytics",
          "targetBlank": false
        }
      ]
    },
