      "description": "Pyroscope profiling backend availability — percentage of requests returning non-5xx responses.",
      "gridPos": { "x": 20, "y": 11, "w": 4, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
