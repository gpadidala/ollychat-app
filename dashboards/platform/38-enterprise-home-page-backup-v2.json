    {
      "id": 12,
      "type": "timeseries",
      "title": "Server Resources",
      "description": "Grafana server process memory and CPU usage over time.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "process_resident_memory_bytes{job=~\".*grafana.*\"}",
