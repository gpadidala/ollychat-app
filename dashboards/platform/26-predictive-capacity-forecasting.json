    {
      "id": 1,
      "title": "Mimir Series — Days to Double",
      "type": "stat",
      "description": "Estimated days until Mimir active series doubles at current growth rate.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(cortex_ingester_active_series{cluster=~\"$cluster\", namespace=~\"$namespace\"}) / clamp_min(deriv(sum(cortex_ingester_active_series{cluster=~\"$cluster\", namespace=~\"$namespace\"})[7d:1h]), 0.001) / 86400",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.6.4"
    },
