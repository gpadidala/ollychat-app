      "panels": [
        {
          "id": 5,
          "title": "Mimir Active Series — Trend & Forecast",
          "type": "timeseries",
          "description": "Active series trend with 30-day linear forecast.",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "gridPos": {
            "h": 9,
            "w": 24,
            "x": 0,
            "y": 7
          },
          "targets": [
            {
              "refId": "A",
              "expr": "sum(cortex_ingester_active_series{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
              "legendFormat": "Active Series (Current)"
            },
            {
              "refId": "B",
              "expr": "predict_linear(sum(cortex_ingester_active_series{cluster=~\"$cluster\", namespace=~\"$namespace\"})[7d:1h], 2592000)",
              "legendFormat": "Predicted (30d)"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "gradientMode": "opacity",
                "lineInterpolation": "smooth",
                "showPoints": "never",
                "spanNulls": true
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "Active Series (Current)"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#6C63FF"
                    }
                  },
                  {
                    "id": "custom.lineWidth",
                    "value": 2
                  },
                  {
                    "id": "custom.fillOpacity",
                    "value": 10
                  },
                  {
                    "id": "custom.lineStyle",
                    "value": {
                      "fill": "solid"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byName",
                  "options": "Predicted (30d)"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "#FF4757"
                    }
                  },
                  {
                    "id": "custom.lineWidth",
                    "value": 2
                  },
                  {
                    "id": "custom.fillOpacity",
                    "value": 0
                  },
                  {
                    "id": "custom.lineStyle",
                    "value": {
                      "fill": "dash",
                      "dash": [
                        10,
                        10
                      ]
                    }
                  }
                ]
              }
            ]
          },
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "calcs": [
                "lastNotNull",
                "mean",
                "min",
                "max"
              ]
            }
          },
          "pluginVersion": "11.6.4"
        }
