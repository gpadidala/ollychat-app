    {
      "id": 2,
      "title": "Profiles/sec",
      "description": "Total rate of profile samples ingested per second across all Pyroscope distributors. Core throughput indicator for profiling volume.",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(pyroscope_distributor_received_samples_total{cluster=~\"$cluster\", namespace=~\"$namespace\", tenant=~\"$tenant\", service_name=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "Profiles/sec",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#651FFF",
                "value": null
              }
            ]
          },
          "color": {
            "fixedColor": "#651FFF",
            "mode": "fixed"
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background_solid",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "pluginVersion": "11.6.4"
    },
