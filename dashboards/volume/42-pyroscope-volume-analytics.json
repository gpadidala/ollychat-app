        "content": "<div style=\"display:flex; align-items:center; justify-content:space-between; padding: 8px 16px;\">\n  <div>\n    <h1 style=\"margin:0; font-size:24px; font-weight:600; color:#E0E0E0; letter-spacing:0.5px;\">Pyroscope — Volume & Throughput Analytics</h1>\n    <p style=\"margin:4px 0 0 0; font-size:13px; color:#999; letter-spacing:0.3px;\">Profile Ingestion Volume • Top Producers • Growth Analysis</p>\n  </div>\n  <div style=\"text-align:right;\">\n    <span style=\"font-size:11px; color:#666; text-transform:uppercase; letter-spacing:1px;\">Signal</span><br/>\n    <span style=\"font-size:14px; color:#651FFF; font-weight:600;\">Continuous Profiling</span>\n  </div>\n</div>",
