{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-azure-monitor-datasource",
      "name": "Azure Monitor",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "azure-functions",
  "title": "Azure — Functions (Serverless)",
  "description": "Comprehensive monitoring of Azure Functions including execution counts, duration, HTTP errors, CPU and memory utilization for serverless workloads.",
  "tags": ["azure", "functions", "serverless", "faas"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": {
          "refId": "A",
          "queryType": "Azure Subscriptions"
        },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": {
          "refId": "A",
          "queryType": "Azure Resource Groups",
          "subscription": "$subscription"
        },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT30M,PT1H,PT6H,PT12H,P1D",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "refresh": 0,
        "sort": 0,
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Function Executions",
      "type": "stat",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "FunctionExecutionCount",
            "aggregation": "Total",
            "timeGrain": "$timeGrain",
            "resourceGroup": "$resourceGroup"
          },
          "subscription": "$subscription"
        }
      ]
    },
    {
      "id": 2,
      "title": "Avg Duration",
      "type": "stat",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "FunctionExecutionUnits",
            "aggregation": "Average",
            "timeGrain": "$timeGrain",
            "resourceGroup": "$resourceGroup"
          },
          "subscription": "$subscription"
        }
      ]
    },
