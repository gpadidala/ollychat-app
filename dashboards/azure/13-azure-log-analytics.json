{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    },
    {
      "name": "DS_AZURE_LOGS",
      "label": "Azure Log Analytics",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-azure-monitor-datasource",
      "name": "Azure Monitor",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Comprehensive KQL workbench for Azure Log Analytics. Query events, errors, performance counters, heartbeat status, and raw logs from any connected workspace.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Event Summary",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Total Events (1h)",
      "description": "Total number of events ingested across all tables in the last hour.",
      "type": "stat",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | where TimeGenerated > ago(1h) | summarize count()",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Error Events",
      "description": "Events with Level == Error in the last hour. Red when 50 or more errors detected.",
      "type": "stat",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | where TimeGenerated > ago(1h) and Level == \"Error\" | summarize count()",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Warning Events",
      "description": "Events with Level == Warning in the last hour.",
      "type": "stat",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | where TimeGenerated > ago(1h) and Level == \"Warning\" | summarize count()",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Unique Sources",
      "description": "Distinct count of log table types seen in the last hour.",
      "type": "stat",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | where TimeGenerated > ago(1h) | summarize dcount(Type)",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "Event Volume",
      "type": "row"
    },
    {
      "id": 5,
      "title": "Events Over Time",
      "description": "Total event count binned in 5-minute intervals across all log tables.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | summarize count() by bin(TimeGenerated, 5m)",
            "resultFormat": "time_series",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"],
          "showLegend": true
        }
      }
    },
    {
      "id": 6,
      "title": "Events by Type",
      "description": "Event count split by log table Type, stacked to show relative contribution.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | summarize count() by Type, bin(TimeGenerated, 5m)",
            "resultFormat": "time_series",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "normal", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"],
          "showLegend": true
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "panels": [],
      "title": "Error Analysis",
      "type": "row"
    },
    {
      "id": 7,
      "title": "Errors Over Time",
      "description": "Error-level events plotted over 5-minute intervals.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | where Level == \"Error\" | summarize count() by bin(TimeGenerated, 5m)",
            "resultFormat": "time_series",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"],
          "showLegend": true
        }
      }
    },
    {
      "id": 8,
      "title": "Top Error Sources",
      "description": "Top 10 log tables producing the most error-level events.",
      "type": "bargauge",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | where Level == \"Error\" | summarize count() by Type | top 10 by count_",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": true
        },
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "panels": [],
      "title": "Performance Logs",
      "type": "row"
    },
    {
      "id": 9,
      "title": "Perf Counters — CPU",
      "description": "Average processor time from Perf table, split by Computer.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "Perf | where ObjectName == \"Processor\" and CounterName == \"% Processor Time\" | summarize avg(CounterValue) by bin(TimeGenerated, 5m), Computer",
            "resultFormat": "time_series",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "percent",
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"],
          "showLegend": true
        }
      }
    },
    {
      "id": 10,
      "title": "Perf Counters — Memory",
      "description": "Average committed bytes in use from Perf table, split by Computer.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "Perf | where ObjectName == \"Memory\" and CounterName == \"% Committed Bytes In Use\" | summarize avg(CounterValue) by bin(TimeGenerated, 5m), Computer",
            "resultFormat": "time_series",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "percent",
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"],
          "showLegend": true
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "panels": [],
      "title": "Heartbeat & Agent",
      "type": "row"
    },
    {
      "id": 11,
      "title": "Agent Heartbeat",
      "description": "Heartbeat count per computer in 5-minute intervals. Gaps indicate agent connectivity issues.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "Heartbeat | summarize count() by bin(TimeGenerated, 5m), Computer",
            "resultFormat": "time_series",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"],
          "showLegend": true
        }
      }
    },
    {
      "id": 12,
      "title": "Missing Heartbeats",
      "description": "Computers whose last heartbeat was more than 15 minutes ago. These agents may be offline or disconnected.",
      "type": "table",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "Heartbeat | summarize LastHeartbeat = max(TimeGenerated) by Computer | where LastHeartbeat < ago(15m)",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "LastHeartbeat", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "panels": [],
      "title": "Raw Log Search",
      "type": "row"
    },
    {
      "id": 13,
      "title": "Recent Events",
      "description": "Last 100 events across all tables. Use this for ad-hoc investigation and quick searches.",
      "type": "table",
      "datasource": "${DS_AZURE_LOGS}",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "targets": [
        {
          "datasource": "${DS_AZURE_LOGS}",
          "queryType": "Azure Log Analytics",
          "azureLogAnalytics": {
            "query": "union * | project TimeGenerated, Type, Level, RenderedDescription | order by TimeGenerated desc | take 100",
            "resultFormat": "table",
            "workspace": "$workspace"
          },
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "TimeGenerated", "desc": true }],
        "cellHeight": "sm",
        "footer": { "show": false }
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["azure", "logs", "loganalytics", "kql"],
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": { "queryType": "Azure Subscriptions" },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": { "queryType": "Azure Resource Groups", "subscription": "$subscription" },
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT30M,PT1H,PT6H,PT12H,P1D",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      },
      {
        "name": "workspace",
        "type": "textbox",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "label": "Log Analytics Workspace",
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "browser",
  "title": "Azure \u2014 Log Analytics & KQL Workbench",
  "uid": "azure-log-analytics",
  "version": 1
}