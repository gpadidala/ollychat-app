{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    },
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "aks-node-deep-dive",
  "title": "AKS — Node Resource Deep Dive",
  "description": "Deep dive into AKS node-level resource utilization including CPU, memory, network, disk, and node conditions for capacity planning and troubleshooting.",
  "tags": ["azure", "aks", "kubernetes", "node", "deep-dive"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 2,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "Subscriptions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "ResourceGroups($subscription)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "textbox",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "label": "Cluster",
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_pod_info{cluster=~\"$cluster\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "label": "Namespace",
        "hide": 0
      },
      {
        "name": "node",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_node_info{cluster=~\"$cluster\"}, node)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "label": "Node",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT1H",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "refresh": 0,
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Node Health Summary",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "id": 1,
      "title": "Nodes Ready",
      "description": "Number of nodes in Ready condition. All nodes should be ready for workload scheduling.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_node_status_condition{cluster=~\"$cluster\", node=~\"$node\", condition=\"Ready\", status=\"true\"})",
          "legendFormat": "Ready Nodes",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "title": "Nodes Not Ready",
      "description": "Nodes not in Ready condition. Any value above 0 means workloads cannot be scheduled on those nodes.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_node_status_condition{cluster=~\"$cluster\", node=~\"$node\", condition=\"Ready\", status=\"false\"})",
          "legendFormat": "Not Ready",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "title": "CPU Requests %",
      "description": "Percentage of total allocatable CPU consumed by resource requests. High values indicate tight scheduling headroom.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", node=~\"$node\", resource=\"cpu\"}) / sum(kube_node_status_allocatable{cluster=~\"$cluster\", node=~\"$node\", resource=\"cpu\"}) * 100",
          "legendFormat": "CPU Requests %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "Memory Requests %",
      "description": "Percentage of total allocatable memory consumed by resource requests. High values indicate tight scheduling headroom.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", node=~\"$node\", resource=\"memory\"}) / sum(kube_node_status_allocatable{cluster=~\"$cluster\", node=~\"$node\", resource=\"memory\"}) * 100",
          "legendFormat": "Memory Requests %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "Disk Pressure",
      "description": "Number of nodes with DiskPressure condition. Any value above 0 indicates nodes running low on disk space.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_node_status_condition{cluster=~\"$cluster\", node=~\"$node\", condition=\"DiskPressure\", status=\"true\"})",
          "legendFormat": "Disk Pressure",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "title": "PID Pressure",
      "description": "Number of nodes with PIDPressure condition. Any value above 0 indicates nodes running low on process IDs.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_node_status_condition{cluster=~\"$cluster\", node=~\"$node\", condition=\"PIDPressure\", status=\"true\"})",
          "legendFormat": "PID Pressure",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "type": "row",
      "title": "CPU",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "panels": []
    },
    {
      "id": 7,
      "title": "CPU Usage by Node",
      "description": "CPU utilization per node over time. Identifies hot nodes that may need rebalancing or scaling.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (node) (rate(node_cpu_seconds_total{cluster=~\"$cluster\", node=~\"$node\", mode!=\"idle\"}[$__rate_interval])) / on(node) group_left count by (node) (node_cpu_seconds_total{cluster=~\"$cluster\", node=~\"$node\", mode=\"idle\"}) * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 8,
      "title": "CPU Requests vs Limits vs Usage",
      "description": "Cluster-wide CPU requests (dashed), limits (dashed), and actual usage. Gaps between requests and usage indicate over-provisioning.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", node=~\"$node\", container!=\"\"}[$__rate_interval]))",
          "legendFormat": "Usage"
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", node=~\"$node\", resource=\"cpu\"})",
          "legendFormat": "Requests"
        },
        {
          "refId": "C",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_limits{cluster=~\"$cluster\", node=~\"$node\", resource=\"cpu\"})",
          "legendFormat": "Limits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }]
          },
          {
            "matcher": { "id": "byName", "options": "Limits" },
            "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "type": "row",
      "title": "Memory",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "panels": []
    },
    {
      "id": 9,
      "title": "Memory Usage by Node",
      "description": "Memory working set per node over time. High memory usage may trigger OOMKills.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "(node_memory_MemTotal_bytes{cluster=~\"$cluster\", node=~\"$node\"} - node_memory_MemAvailable_bytes{cluster=~\"$cluster\", node=~\"$node\"}) / node_memory_MemTotal_bytes{cluster=~\"$cluster\", node=~\"$node\"} * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 10,
      "title": "Memory Requests vs Limits vs Usage",
      "description": "Cluster-wide memory requests (dashed), limits (dashed), and actual usage. Large gaps indicate over-provisioning.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(container_memory_working_set_bytes{cluster=~\"$cluster\", node=~\"$node\", container!=\"\"})",
          "legendFormat": "Usage"
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", node=~\"$node\", resource=\"memory\"})",
          "legendFormat": "Requests"
        },
        {
          "refId": "C",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_limits{cluster=~\"$cluster\", node=~\"$node\", resource=\"memory\"})",
          "legendFormat": "Limits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }]
          },
          {
            "matcher": { "id": "byName", "options": "Limits" },
            "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "type": "row",
      "title": "Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "panels": []
    },
    {
      "id": 11,
      "title": "Network Receive by Node",
      "description": "Network bytes received per node. Identifies nodes handling disproportionate inbound traffic.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (node) (rate(node_network_receive_bytes_total{cluster=~\"$cluster\", node=~\"$node\", device!~\"lo|veth.*|docker.*|flannel.*|cali.*|cbr.*\"}[$__rate_interval]))",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 12,
      "title": "Network Transmit by Node",
      "description": "Network bytes transmitted per node. Identifies nodes with high outbound traffic.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (node) (rate(node_network_transmit_bytes_total{cluster=~\"$cluster\", node=~\"$node\", device!~\"lo|veth.*|docker.*|flannel.*|cali.*|cbr.*\"}[$__rate_interval]))",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "type": "row",
      "title": "Disk",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 104,
      "panels": []
    },
    {
      "id": 13,
      "title": "Filesystem Usage % by Node",
      "description": "Filesystem usage percentage per node. Values above 85% risk pod evictions due to disk pressure.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 34 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "(1 - node_filesystem_avail_bytes{cluster=~\"$cluster\", node=~\"$node\", mountpoint=\"/\", fstype!~\"tmpfs|fuse.*\"} / node_filesystem_size_bytes{cluster=~\"$cluster\", node=~\"$node\", mountpoint=\"/\", fstype!~\"tmpfs|fuse.*\"}) * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 14,
      "title": "Disk I/O by Node",
