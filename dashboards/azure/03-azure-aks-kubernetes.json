            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Node Disk Usage Over Time",
      "description": "Node disk usage percentage trend. Consistently rising disk usage may require increasing node disk sizes or enabling ephemeral OS disks.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
