            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Pods & Disk",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Pod Count Over Time",
      "description": "Pod count trend across the AKS cluster. Monitor pod churn and scaling events to ensure workload stability.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "kube_pod_status_ready",
            "aggregation": "Average",
