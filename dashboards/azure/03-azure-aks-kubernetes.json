      "title": "Network In Bytes Over Time",
      "description": "Inbound network bytes across AKS cluster nodes. Spikes may indicate increased ingress traffic or inter-pod communication.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
