{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-azure-monitor-datasource",
      "name": "Azure Monitor",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "row",
      "name": "Row",
      "version": ""
    }
  ],
  "id": null,
  "uid": "azure-aks-kubernetes",
  "title": "Azure — AKS Kubernetes Cluster",
  "description": "Comprehensive monitoring for Azure Kubernetes Service (AKS) covering node CPU/memory, pod counts, disk usage, network throughput, and API server health.",
  "tags": ["azure", "aks", "kubernetes"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "Subscriptions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "ResourceGroups($subscription)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT30M,PT1H,PT6H,PT12H,P1D",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "refresh": 0,
        "sort": 0,
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "AKS Cluster Key Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Node CPU %",
      "description": "Average CPU utilization percentage across AKS cluster nodes. Sustained values above 80% suggest the need for node pool scaling.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_cpu_usage_percentage",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Node Memory %",
      "description": "Average memory utilization percentage across AKS cluster nodes. High memory pressure can cause OOMKill events.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_memory_working_set_percentage",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Pod Count",
      "description": "Number of pods in Ready state across the cluster. Track against cluster capacity limits for scaling decisions.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "kube_pod_status_ready",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Disk Used %",
      "description": "Node disk usage percentage. High disk usage may impact pod scheduling and ephemeral storage claims.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_disk_usage_percentage",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Network In",
      "description": "Total inbound network bytes across cluster nodes. High inbound traffic may indicate heavy ingress load.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_network_in_bytes",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 5368709120 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "API Server Requests",
      "description": "Number of inflight requests to the Kubernetes API server. Excessive API calls may throttle control plane operations.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "apiserver_current_inflight_requests",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 400 },
              { "color": "red", "value": 800 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Node CPU & Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Node CPU Utilization Over Time",
      "description": "AKS node CPU utilization trend. Identify peak usage windows for Horizontal Pod Autoscaler and Cluster Autoscaler tuning.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_cpu_usage_percentage",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Node Memory Working Set Over Time",
      "description": "AKS node memory working set percentage. Sustained high memory usage triggers pod eviction via kubelet thresholds.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_memory_working_set_percentage",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
