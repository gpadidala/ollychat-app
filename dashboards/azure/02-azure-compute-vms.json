        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Network Out",
      "description": "Total network bytes transmitted by VMs. Correlate with application traffic patterns and data egress costs.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.compute/virtualmachines",
            "metricNamespace": "microsoft.compute/virtualmachines",
            "metricName": "Network Out Total",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1073741824 },
              { "color": "red", "value": 5368709120 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "CPU & Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "CPU Utilization Over Time",
      "description": "VM CPU utilization trend. Identify peak usage windows and sustained high-CPU periods to plan scaling actions.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.compute/virtualmachines",
            "metricNamespace": "microsoft.compute/virtualmachines",
            "metricName": "Percentage CPU",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Available Memory Over Time",
      "description": "Available memory bytes trend. Decreasing free memory over time may signal a memory leak in applications.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.compute/virtualmachines",
            "metricNamespace": "microsoft.compute/virtualmachines",
            "metricName": "Available Memory Bytes",
            "aggregation": "Average",
