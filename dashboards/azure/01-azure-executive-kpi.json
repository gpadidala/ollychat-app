{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-azure-monitor-datasource",
      "name": "Azure Monitor",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "azure-executive-kpi",
  "title": "Azure — Executive KPI Dashboard",
  "description": "The single pane of glass for Azure platform leadership. Large stat panels for instant health, multi-service trends, quality metrics, and navigation links to all Azure dashboards.",
  "tags": ["azure", "executive", "kpi", "leadership"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "Subscriptions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "ResourceGroups($subscription)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT1H,P1D",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"text-align:center;padding:8px 0\">\n  <h1 style=\"margin:0;font-size:1.6rem;color:#58a6ff\">Azure Platform — Executive KPI</h1>\n  <span style=\"color:#8b949e;font-size:0.85rem\">Subscription: $subscription | Resource Group: $resourceGroup | Grain: $timeGrain</span>\n</div>"
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Key Performance Indicators",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "VM CPU %",
      "description": "Average CPU utilization across all Virtual Machines in the selected resource group. Sustained values above 90% indicate capacity risk.",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 2 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.compute/virtualmachines",
            "metricNamespace": "microsoft.compute/virtualmachines",
            "metricName": "Percentage CPU",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "App Service Requests",
      "description": "Total requests hitting App Service web apps. A sudden drop may indicate an outage; a spike may indicate a traffic surge.",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 2 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Requests",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "SQL DTU %",
      "description": "Average DTU consumption across SQL databases. Sustained values above 90% require scaling up the service tier.",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 2 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.sql/servers/databases",
            "metricNamespace": "microsoft.sql/servers/databases",
            "metricName": "dtu_consumption_percent",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "AKS Node CPU %",
      "description": "Average node-level CPU utilization across AKS managed clusters. High values may require node pool scaling.",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 2 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "node_cpu_usage_percentage",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "API 5xx Errors",
      "description": "Total HTTP 5xx server errors from App Service. Any value above 0 warrants investigation; above 10 is a potential outage.",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 2 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Http5xx",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Storage Used",
      "description": "Average used capacity across Azure Storage accounts in the resource group.",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 2 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.storage/storageaccounts",
            "metricNamespace": "microsoft.storage/storageaccounts",
            "metricName": "UsedCapacity",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 85899345920 },
              { "color": "red", "value": 214748364800 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Multi-Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "VM CPU Trend",
      "description": "CPU utilization trend for Virtual Machines over time. Use this to identify spikes and sustained high usage patterns.",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 7 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.compute/virtualmachines",
            "metricNamespace": "microsoft.compute/virtualmachines",
            "metricName": "Percentage CPU",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "App Service Response Time",
      "description": "Average response time for App Service web apps. Increasing latency may signal backend issues or scaling needs.",
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 7 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "AverageResponseTime",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "SQL DB CPU",
      "description": "DTU consumption percentage trend for SQL databases. Correlate with query workloads to right-size tiers.",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 7 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.sql/servers/databases",
            "metricNamespace": "microsoft.sql/servers/databases",
            "metricName": "dtu_consumption_percent",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "AKS Pod Count",
      "description": "Number of ready pods in AKS clusters over time. Drops indicate pod failures or evictions.",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 7 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.containerservice/managedclusters",
            "metricNamespace": "microsoft.containerservice/managedclusters",
            "metricName": "kube_pod_status_ready",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Quality & Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "App Service Error Rate",
      "description": "Percentage of requests resulting in HTTP 5xx errors. Even 1% error rate should trigger investigation.",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 14 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Http5xx",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        },
        {
          "refId": "B",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Requests",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "reduce": { "reducer": "sum" },
            "binary": {
              "left": "A",
              "operator": "/",
              "right": "B"
            },
            "alias": "Error Rate %"
          }
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "API Latency P95",
      "description": "Average response time as a proxy for P95 latency. Values above 500ms degrade user experience.",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 14 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "AverageResponseTime",
            "aggregation": "Average",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "SQL Deadlocks",
      "description": "Total deadlock events on SQL databases. Any deadlock indicates contention that should be resolved at the query/schema level.",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 14 },
      "datasource": "${DS_AZURE_MONITOR}",
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.sql/servers/databases",
            "metricNamespace": "microsoft.sql/servers/databases",
            "metricName": "deadlock",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "continuous-GrYlRd" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Navigation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "id": 40,
      "type": "text",
      "title": "Azure Dashboard Navigation",
      "description": "Quick links to all Azure observability dashboards for drill-down investigation.",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 21 },
