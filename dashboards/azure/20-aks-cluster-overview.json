{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    },
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Azure Managed)",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-azure-monitor-datasource",
      "name": "Azure Monitor",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "aks-cluster-overview",
  "title": "AKS — Cluster Overview & Health",
  "description": "The entry-point AKS dashboard providing a comprehensive at-a-glance view of cluster health, resource usage, pod status, node health, network traffic, and persistent volume storage across all AKS clusters.",
  "tags": ["azure", "aks", "kubernetes", "cluster", "overview"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 2,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "Subscriptions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "ResourceGroups($subscription)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_node_info, cluster)",
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Cluster",
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_pod_info{cluster=~\"$cluster\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "label": "Namespace",
        "hide": 0
      },
      {
        "name": "node",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_node_info{cluster=~\"$cluster\"}, node)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "label": "Node",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT1H",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "refresh": 0,
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Cluster Health Summary",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "id": 1,
      "title": "Cluster Status",
      "description": "Number of nodes in Ready condition. A value >= 1 indicates the cluster is operational.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "count(kube_node_status_condition{cluster=~\"$cluster\", condition=\"Ready\", status=\"true\"})",
          "legendFormat": "Ready Nodes",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "title": "Total Nodes",
      "description": "Total number of nodes registered in the AKS cluster.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 3, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "count(kube_node_info{cluster=~\"$cluster\"})",
          "legendFormat": "Nodes",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "title": "Total Pods",
      "description": "Total number of pods currently in Running phase across all namespaces.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 6, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_status_phase{cluster=~\"$cluster\", phase=\"Running\"})",
          "legendFormat": "Running Pods",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "Pending Pods",
      "description": "Pods stuck in Pending phase. High values indicate scheduling issues — check node capacity, taints, or resource requests.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 9, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_status_phase{cluster=~\"$cluster\", phase=\"Pending\"})",
          "legendFormat": "Pending Pods",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "Failed Pods",
      "description": "Pods in Failed phase. Any failed pods require immediate investigation.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_status_phase{cluster=~\"$cluster\", phase=\"Failed\"})",
          "legendFormat": "Failed Pods",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "title": "CPU Usage %",
      "description": "Cluster-wide CPU utilization as a percentage of total allocatable CPU across all nodes.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 15, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", container!=\"\"}[$__rate_interval])) / sum(kube_node_status_allocatable{cluster=~\"$cluster\", resource=\"cpu\"}) * 100",
          "legendFormat": "CPU %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 7,
      "title": "Memory Usage %",
      "description": "Cluster-wide memory utilization as a percentage of total allocatable memory across all nodes.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 18, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(container_memory_working_set_bytes{cluster=~\"$cluster\", container!=\"\"}) / sum(kube_node_status_allocatable{cluster=~\"$cluster\", resource=\"memory\"}) * 100",
          "legendFormat": "Memory %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 8,
      "title": "Pod Restarts (1h)",
      "description": "Total container restarts across the cluster in the last hour. Frequent restarts indicate instability — check OOMKills, CrashLoopBackOff, or liveness probe failures.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 3, "x": 21, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{cluster=~\"$cluster\"}[1h]))",
          "legendFormat": "Restarts",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "type": "row",
      "title": "Cluster Resource Usage",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "panels": []
    },
    {
      "id": 9,
      "title": "Cluster CPU Usage vs Capacity",
      "description": "CPU usage compared to allocatable capacity and total requests. The gap between Used and Requested shows overprovisioning, while Used approaching Allocatable signals capacity risk.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\", container!=\"\"}[$__rate_interval]))",
          "legendFormat": "Used"
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_node_status_allocatable{cluster=~\"$cluster\", resource=\"cpu\"})",
          "legendFormat": "Allocatable"
        },
        {
          "refId": "C",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", resource=\"cpu\"})",
          "legendFormat": "Requested"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Allocatable" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Requested" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 10,
      "title": "Cluster Memory Usage vs Capacity",
      "description": "Memory usage compared to allocatable capacity and total requests. Monitor for memory pressure when Used approaches Allocatable.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(container_memory_working_set_bytes{cluster=~\"$cluster\", container!=\"\"})",
          "legendFormat": "Used"
        },
        {
          "refId": "B",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_node_status_allocatable{cluster=~\"$cluster\", resource=\"memory\"})",
          "legendFormat": "Allocatable"
        },
        {
          "refId": "C",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_pod_container_resource_requests{cluster=~\"$cluster\", resource=\"memory\"})",
          "legendFormat": "Requested"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Allocatable" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Requested" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "type": "row",
      "title": "Pod Status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "panels": []
    },
    {
      "id": 11,
      "title": "Pod Count by Phase",
      "description": "Distribution of pods across lifecycle phases. Running should dominate; persistent Pending or Failed pods require attention.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (phase) (kube_pod_status_phase{cluster=~\"$cluster\"})",
          "legendFormat": "{{phase}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "normal", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Running" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Failed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Succeeded" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#B877D9" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 12,
      "title": "Pod Count by Namespace",
      "description": "Running pod distribution across namespaces. Identifies which namespaces consume the most pod capacity.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (namespace) (kube_pod_status_phase{cluster=~\"$cluster\", phase=\"Running\"})",
          "legendFormat": "{{namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
