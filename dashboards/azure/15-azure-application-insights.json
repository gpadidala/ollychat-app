    {
      "id": 1,
      "title": "Server Requests",
      "description": "Total count of server requests processed by the application.",
      "type": "stat",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_AZURE_MONITOR}",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.insights/components",
            "metricName": "requests/count",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          },
          "subscription": "$subscription",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
