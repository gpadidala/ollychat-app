        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "Http 4xx",
      "description": "Total HTTP 4xx (client error) responses. High values indicate client-side issues such as bad requests or unauthorized access.",
      "type": "stat",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
