    {
      "id": 12,
      "title": "Connections",
      "description": "Number of active connections to the App Service. A spike in connections may indicate connection leaks or increased load.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
