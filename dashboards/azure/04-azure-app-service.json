        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": []
    },
    {
      "id": 7,
      "title": "Request Rate",
      "description": "Total requests over time. Use this to identify traffic patterns, peak hours, and anomalies.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Requests",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 8,
      "title": "Response Time",
      "description": "Average response time over time. Spikes indicate performance degradation — correlate with CPU/memory usage.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "AverageResponseTime",
            "aggregation": "Average",
