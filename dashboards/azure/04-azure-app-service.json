      "id": 102,
      "panels": []
    },
    {
      "id": 9,
      "title": "HTTP Status Codes",
      "description": "Stacked view of HTTP status code families over time. Green (2xx) is healthy; yellow (4xx) is client errors; red (5xx) is server errors.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "refId": "A",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Http2xx",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        },
        {
          "refId": "B",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Http4xx",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        },
        {
          "refId": "C",
          "queryType": "Azure Monitor",
          "azureMonitor": {
            "resourceGroup": "$resourceGroup",
            "metricDefinition": "microsoft.web/sites",
            "metricNamespace": "microsoft.web/sites",
            "metricName": "Http5xx",
            "aggregation": "Total",
            "timeGrain": "$timeGrain"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Http2xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Http4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Http5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 10,
