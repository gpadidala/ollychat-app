    {
      "id": 13,
      "title": "NSG Flow Logs",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
      "description": "NSG flow log metrics. Requires NSG Flow Logs to be enabled and flowing to Azure Monitor. If no data appears, verify NSG Flow Logs configuration.",
