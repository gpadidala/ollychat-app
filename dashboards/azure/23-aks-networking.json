{
  "__inputs": [
    {
      "name": "DS_AZURE_MONITOR",
      "label": "Azure Monitor",
      "type": "datasource",
      "pluginId": "grafana-azure-monitor-datasource"
    },
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    }
  ],
  "id": null,
  "uid": "aks-networking",
  "title": "AKS — Network & Service Mesh",
  "description": "Comprehensive AKS network monitoring including service counts, endpoint health, namespace-level traffic, top pod bandwidth consumers, errors, and packet metrics.",
  "tags": ["azure", "aks", "kubernetes", "network"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 2,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "subscription",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "Subscriptions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Subscription",
        "hide": 0
      },
      {
        "name": "resourceGroup",
        "type": "query",
        "datasource": "${DS_AZURE_MONITOR}",
        "query": "ResourceGroups($subscription)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Resource Group",
        "hide": 0
      },
      {
        "name": "cluster",
        "type": "textbox",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        },
        "label": "Cluster",
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(kube_pod_info{cluster=~\"$cluster\"}, namespace)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "label": "Namespace",
        "hide": 0
      },
      {
        "name": "timeGrain",
        "type": "custom",
        "query": "auto,PT1M,PT5M,PT15M,PT1H",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "refresh": 0,
        "includeAll": false,
        "multi": false,
        "label": "Time Grain",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Network Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": []
    },
    {
      "id": 1,
      "title": "Services",
      "description": "Total number of Kubernetes services across selected namespaces.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "count(kube_service_info{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "Services",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "title": "Endpoints",
      "description": "Total number of ready endpoints backing Kubernetes services.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(kube_endpoint_address_available{cluster=~\"$cluster\", namespace=~\"$namespace\"})",
          "legendFormat": "Endpoints",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "title": "Network Receive Rate",
      "description": "Aggregate network receive rate across all pods in the cluster.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_network_receive_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Receive",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "Network Transmit Rate",
      "description": "Aggregate network transmit rate across all pods in the cluster.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_network_transmit_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Transmit",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "Receive Errors",
      "description": "Total network receive errors. Any errors indicate network-level issues requiring investigation.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_network_receive_errors_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Rx Errors",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 6,
      "title": "Transmit Errors",
      "description": "Total network transmit errors. Any errors indicate network-level issues requiring investigation.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(container_network_transmit_errors_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Tx Errors",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "type": "row",
      "title": "Namespace Network",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "panels": []
    },
    {
      "id": 7,
      "title": "Network Receive by Namespace",
      "description": "Network receive bytes per second stacked by namespace. Identifies which namespaces drive the most inbound traffic.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (namespace) (rate(container_network_receive_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "stacking": { "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "id": 8,
      "title": "Network Transmit by Namespace",
      "description": "Network transmit bytes per second stacked by namespace. Identifies which namespaces drive the most outbound traffic.",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (namespace) (rate(container_network_transmit_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
