        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }
      }
    },
    {
      "type": "row",
      "title": "Top Pods",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "panels": []
    },
    {
      "id": 9,
      "title": "Top 10 Pods by Receive",
      "description": "Top 10 pods by network receive bytes per second. Identifies bandwidth-heavy consumers.",
      "type": "bargauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "expr": "topk(10, sum by (pod) (rate(container_network_receive_bytes_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])))",
          "legendFormat": "{{pod}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10485760 },
              { "color": "red", "value": 104857600 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      }
    },
    {
      "id": 10,
      "title": "Top 10 Pods by Transmit",
      "description": "Top 10 pods by network transmit bytes per second. Identifies bandwidth-heavy producers.",
      "type": "bargauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
