      "id": 5,
      "title": "VM CPU Utilization — 30d Trend",
      "description": "30-day VM CPU utilization pattern. Look for consistently low utilization (< 20%) indicating overprovisioned VMs that can be downsized. Identify peak periods to determine if reserved instances would be cost-effective.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
