            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "min"],
          "showLegend": true
        }
      }
    },
    {
      "id": 6,
      "title": "VM Memory Utilization — 30d Trend",
      "description": "30-day VM available memory trend. Consistently high available memory (low utilization) suggests VMs can be downsized to a smaller SKU. Decreasing trends may indicate a memory leak.",
      "type": "timeseries",
      "datasource": "${DS_AZURE_MONITOR}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
