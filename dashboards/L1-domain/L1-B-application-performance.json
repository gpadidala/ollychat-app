      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "heatmap",
      "name": "Heatmap",
      "version": ""
    },
    {
      "type": "panel",
      "id": "row",
      "name": "Row",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "enable": true,
        "expr": "changes(process_start_time_seconds{cluster=~\"$cluster\", namespace=~\"$namespace\"}[5m]) > 0",
        "hide": false,
        "iconColor": "#FFA500",
        "name": "Service Restarts",
        "step": "60s",
        "tagKeys": "cluster,namespace",
        "titleFormat": "Restart: {{pod}}",
        "type": "tags"
      }
    ]
  },
  "description": "Director-level application health using RED metrics (Rate, Errors, Duration) across all services. Golden signals matrix with drill-down to service dashboards.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 2,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "L0: Command Center",
      "tooltip": "Back to L0 Executive Command Center",
      "type": "link",
      "url": "/d/l0-executive-command-center/"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "L1: Infrastructure",
      "tooltip": "L1 Infrastructure Overview",
      "type": "link",
      "url": "/d/l1-infrastructure-overview/"
    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "L1: Profiling",
      "tooltip": "L1 Profiling Overview",
      "type": "link",
      "url": "/d/l1-profiling-overview/"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "description": "Breadcrumb navigation and lateral links across L0/L1 dashboards.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-size:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;\">\n  <a href=\"/d/l0-executive-command-center/\" style=\"color:#6E9FFF; text-decoration:none;\">&larr; Back to Command Center</a>\n  <span style=\"color:#aaa;\">|</span>\n  <span style=\"color:#ccc;\"><a href=\"/d/l0-executive-command-center/\" style=\"color:#6E9FFF; text-decoration:none;\">L0: Command Center</a> &rarr; <strong style=\"color:#FF9830;\">L1: Applications</strong></span>\n  <span style=\"color:#aaa;\">|</span>\n  <a href=\"/d/l1-infrastructure-overview/\" style=\"color:#6E9FFF; text-decoration:none;\">[Infrastructure]</a>\n  <a href=\"/d/l1-profiling-overview/\" style=\"color:#6E9FFF; text-decoration:none;\">[Profiling]</a>\n</div>"
      },
      "datasource": {
        "type": "datasource",
        "uid": "grafana"
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Golden Signals Summary",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Request Rate",
      "description": "Aggregate HTTP request rate across all services in the selected clusters and namespaces. A sudden drop may indicate an outage.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "Total RPS",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Global Error Rate",
      "description": "Percentage of HTTP 5xx responses across all services. Thresholds: green <1%, amber 1-5%, red >5%.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum(rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) * 100",
          "legendFormat": "Error Rate %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P50 Latency",
      "description": "Median (50th percentile) HTTP request duration across all services. Represents the typical user experience.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "P95 Latency",
      "description": "95th percentile HTTP request duration. Represents the tail latency experienced by 1-in-20 requests. Thresholds: green <500ms, amber 500ms-1s, red >1s.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "P99 Latency",
      "description": "99th percentile HTTP request duration. Worst-case latency for 1-in-100 requests. Thresholds: green <1s, amber 1-2s, red >2s.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Services Healthy",
      "description": "Count of services with error rate below 1%. A service is considered healthy when fewer than 1% of its requests return 5xx status codes.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(sum by (job) (rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) < 0.01)",
          "legendFormat": "Healthy Services",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Request & Error Trends",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Request Rate by Service",
      "description": "HTTP request rate broken down by service (job). Identify traffic distribution and detect anomalous spikes or drops per service.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "description": "HTTP 5xx error rate per service as a percentage of total requests. Amber threshold at 1%, red at 5% on the y-axis.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Latency Distribution",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Latency Percentiles Over Time",
      "description": "P50, P95, and P99 HTTP request latency over time across all services. Use this to identify latency regressions and correlate with deployments.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 11,
      "type": "heatmap",
      "title": "Latency Heatmap",
      "description": "Request duration distribution as a heatmap. Darker bands indicate latency concentrations. Useful for spotting bimodal distributions or latency outliers.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(http_request_duration_seconds_bucket{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": {},
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "fill": "dark",
          "reverse": true,
          "exponent": 0.5,
          "steps": 64
        },
        "cellGap": 1,
        "filterValues": {
          "le": 1e-9
        },
        "tooltip": {
          "show": true,
          "yHistogram": true
        },
        "yAxis": {
          "unit": "s",
          "reverse": false
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "showValue": "never",
        "legend": {
          "show": true
        }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Top Problem Services",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "panels": []
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Top 5 Highest Error Rate",
      "description": "Services with the highest HTTP 5xx error rate percentage. Click a service to drill down to its L2 golden signals dashboard.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum by (job) (rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) / (sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) * 100)",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "decimals": 2,
          "links": [
            {
              "title": "Drill down to service golden signals",
