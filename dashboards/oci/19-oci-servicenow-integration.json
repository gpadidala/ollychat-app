{
  "__inputs": [
    {
      "name": "DS_OCI_METRICS",
      "label": "OCI Metrics",
      "type": "datasource",
      "pluginId": "oci-metrics-datasource"
    },
    {
      "name": "DS_OCI_LOGS",
      "label": "OCI Logs",
      "type": "datasource",
      "pluginId": "oci-logs-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-metrics-datasource",
      "name": "OCI Metrics",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-logs-datasource",
      "name": "OCI Logs",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "id": null,
  "uid": "oci-servicenow-integration",
  "title": "OCI + ServiceNow \u2014 Incident Correlation",
  "description": "Correlate OCI infrastructure metrics and logs with ServiceNow incident, change, and deployment events. Identify whether infrastructure degradation aligns with ITSM incidents and change windows.",
  "tags": ["oci", "servicenow", "itsm", "incidents", "correlation"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "regions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Region",
        "hide": 0
      },
      {
        "name": "compartment",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "compartments($region)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Compartment",
        "hide": 0
      },
      {
        "name": "window",
        "type": "custom",
        "query": "auto,1m,5m,15m,1h,1d",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Window",
        "hide": 0
      },
      {
        "name": "incident_keyword",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "label": "Incident Keyword",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Header",
      "type": "row"
    },
    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:8px 16px;\">\n  <h2 style=\"margin:0;color:#fff;font-size:20px;\">OCI + ServiceNow \u2014 Incident Correlation</h2>\n  <span style=\"background:#e74c3c;color:#fff;padding:4px 14px;border-radius:12px;font-weight:bold;font-size:13px;letter-spacing:1px;animation:pulse 2s infinite;\">&#9679; CORRELATION</span>\n</div>\n<style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}</style>"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "id": 101,
      "panels": [],
      "title": "Key Indicators",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Platform CPU %",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "description": "Average compute CPU utilization across the platform. High values during incidents confirm resource pressure.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 2 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_computeagent",
          "query": "CpuUtilization[$window].mean()",
          "legendFormat": "{{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "DB Health %",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "description": "Autonomous database storage utilization. High values during incidents may indicate storage-related issues.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 2 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_autonomous_database",
          "query": "StorageUtilization[$window].max()",
          "legendFormat": "{{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "API Error Rate",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "description": "API Gateway 5xx errors. Spikes during incident windows confirm service degradation.",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 2 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_apigateway",
          "query": "Errors5xx[$window].sum()",
          "legendFormat": "{{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Incident Events",
      "type": "stat",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Log events containing incident or INC references. Indicates ServiceNow incident correlation points.",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 2 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'incident|INC' | summarize count() as Incidents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Change Events",
      "type": "stat",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Deploy, change, and release events detected in logs. Correlate with incident timelines.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 2 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.eventName =~ 'Change|Deploy|Release' | summarize count() as Changes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "title": "Failed Changes",
      "type": "stat",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Failed change, deploy, or rollback events. Any failed change is a potential incident root cause.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 2 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'change.*failed|deploy.*failed|rollback' | summarize count() as Failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 102,
      "panels": [],
      "title": "Infrastructure During Incidents",
      "type": "row"
    },
    {
      "id": 8,
      "title": "CPU Utilization",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "description": "Compute CPU utilization over time. Overlay with incident timelines to confirm resource pressure during outages.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_computeagent",
          "query": "CpuUtilization[$window].mean()",
          "legendFormat": "{{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "title": "DB CPU + Queued Statements",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "description": "Database CPU and queued statement count. High queued statements during incidents indicate database bottlenecks.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_autonomous_database",
          "query": "CpuUtilization[$window].mean()",
          "legendFormat": "DB CPU {{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "A"
        },
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_autonomous_database",
          "query": "QueuedStatements[$window].max()",
          "legendFormat": "Queued {{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 103,
      "panels": [],
      "title": "Error Correlation",
      "type": "row"
    },
    {
      "id": 10,
      "title": "Error Events Over Time",
      "type": "timeseries",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Correlate spikes with ServiceNow incident times. Error bursts that align with INC tickets confirm infrastructure root cause.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'error|Error|ERROR' | summarize count() as Errors by rounddown(datetime, '5m')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "title": "Incident-Related Events",
      "type": "timeseries",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Events matching incident keywords over time. Use the Incident Keyword variable to filter by specific INC numbers.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ '$incident_keyword|incident|INC' | summarize count() by rounddown(datetime, '5m')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 104,
      "panels": [],
      "title": "Change Tracking",
      "type": "row"
    },
    {
      "id": 12,
      "title": "Deploy/Change Events",
      "type": "timeseries",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Deploy, change, and release events over time. Incidents following a change event suggest change-related failures.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.eventName =~ 'Deploy|Change|Release' | summarize count() as Events by rounddown(datetime, '1h')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 13,
      "title": "API Errors Around Changes",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "description": "API Gateway 5xx errors over time. Overlay with change events to identify change-induced failures.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_apigateway",
          "query": "Errors5xx[$window].sum()",
          "legendFormat": "5xx {{resourceDisplayName}}",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
