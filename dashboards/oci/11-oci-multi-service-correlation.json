            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
