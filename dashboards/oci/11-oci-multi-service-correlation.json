    {
      "id": 10,
      "title": "Block Storage I/O",
      "description": "Read and write IOPS for OCI Block Volumes. Correlate I/O spikes with compute CPU and database activity to identify storage-bound workloads.",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
