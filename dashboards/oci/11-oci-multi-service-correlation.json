{
  "__inputs": [
    {
      "name": "DS_OCI_METRICS",
      "label": "OCI Metrics",
      "type": "datasource",
      "pluginId": "oci-metrics-datasource"
    },
    {
      "name": "DS_OCI_LOGS",
      "label": "OCI Logs",
      "type": "datasource",
      "pluginId": "oci-logs-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-metrics-datasource",
      "name": "OCI Metrics",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-logs-datasource",
      "name": "OCI Logs",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "id": null,
  "uid": "oci-multi-service-correlation",
  "title": "OCI Multi-Service Correlation",
  "description": "Cross-service correlation dashboard for OCI workloads. Shared time range and annotations enable correlating metric spikes across compute, database, network, API, functions, and storage layers with log error events.",
  "tags": ["oci", "correlation", "multi-service", "advanced"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 2,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "regions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Region",
        "hide": 0
      },
      {
        "name": "compartment",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "compartments($region)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Compartment",
        "hide": 0
      },
      {
        "name": "window",
        "type": "custom",
        "query": "auto,1m,5m,15m,1h,1d",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Window",
        "hide": 0
      },
      {
        "name": "namespace_filter",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "namespaces($region,$compartment)",
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "label": "Namespace Filter",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Compute Layer",
      "type": "row"
    },
    {
      "id": 1,
      "title": "CPU Utilization",
      "description": "Mean CPU utilization across compute instances. Correlate spikes here with database, network, and log panels below to identify root causes.",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_computeagent",
          "query": "CpuUtilization[$window].mean()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "{{resourceDisplayName}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Utilization",
      "description": "Mean memory utilization across compute instances. Memory pressure often correlates with increased swap and degraded application performance.",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
