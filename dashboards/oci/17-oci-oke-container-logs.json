      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 35 },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": true, "enablePagination": true, "fields": "", "reducer": ["count"], "show": true },
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "datetime" }
        ]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'error|Error|OOMKilled|CrashLoopBackOff' | sort by datetime desc"
        }
      ],
      "title": "Container Error Logs",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "auto",
            "replace": false,
            "source": "data"
          }
        },
        {
          "id": "organize",
