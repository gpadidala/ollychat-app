            "inspect": true,
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "datetime" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          }
        ]
