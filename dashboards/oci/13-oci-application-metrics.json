          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": []
