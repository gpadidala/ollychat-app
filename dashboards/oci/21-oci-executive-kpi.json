{
  "__inputs": [
    {
      "name": "DS_OCI_METRICS",
      "label": "OCI Metrics",
      "type": "datasource",
      "pluginId": "oci-metrics-datasource"
    },
    {
      "name": "DS_OCI_LOGS",
      "label": "OCI Logs",
      "type": "datasource",
      "pluginId": "oci-logs-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-metrics-datasource",
      "name": "OCI Metrics",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-logs-datasource",
      "name": "OCI Logs",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "oci-executive-kpi",
  "title": "OCI Executive KPI \u2014 Leadership Dashboard",
  "description": "The single dashboard an OCI platform leader opens every morning. Large stat panels for instant health checks, multi-service trend strips, capacity signals, and service quality metrics \u2014 all with drill-down links.",
  "tags": ["oci", "executive", "kpi", "leadership", "c-suite"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "regions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Region",
        "hide": 0
      },
      {
        "name": "compartment",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "compartments($region)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Compartment",
        "hide": 0
      },
      {
        "name": "window",
        "type": "custom",
        "query": "auto,1m,5m,15m,1h,1d",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Window",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Header",
      "type": "row"
    },
    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:8px 16px;\">\n  <h2 style=\"margin:0;color:#fff;font-size:20px;\">OCI Platform \u2014 Executive KPI Dashboard</h2>\n  <span style=\"background:#2ecc71;color:#fff;padding:4px 14px;border-radius:12px;font-weight:bold;font-size:13px;letter-spacing:1px;animation:pulse 2s infinite;\">&#9679; LIVE</span>\n</div>\n<style>@keyframes pulse{0%,100%{opacity:1}50%{opacity:.6}}</style>"
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "id": 101,
      "title": "The Big Numbers",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Compute Health %",
      "description": "Average CPU utilization across all compute instances. Lower values indicate more headroom. Thresholds: green < 70%, yellow < 90%, red >= 90%.",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 2 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_computeagent",
          "query": "CpuUtilization[$window].mean()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "CPU Utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "links": [
        {
          "title": "Compute Deep Dive",
          "url": "/d/oci-compute-deep-dive",
          "targetBlank": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Database Health %",
