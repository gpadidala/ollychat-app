        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Get Requests",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_objectstorage",
