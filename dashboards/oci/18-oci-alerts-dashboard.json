    {
      "id": 17,
      "title": "Error Log Rate (Alert Trigger)",
      "description": "Error log count per 5 minutes from OCI Logs. Threshold at 50 errors triggers alert.",
      "type": "timeseries",
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 51 },
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'error|Error|ERROR|exception|Exception' | summarize count() as Errors by rounddown(datetime, '5m')"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": false,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "area" }
          }
        },
