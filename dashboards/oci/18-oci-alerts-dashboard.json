    {
      "id": 12,
      "title": "Backend Health",
      "description": "Total backend servers vs unhealthy backend servers. Healthy=green, Unhealthy=red.",
      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_lbaas",
          "query": "BackendServers[$window].mean()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "Healthy Backends",
          "refId": "A"
        },
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_lbaas",
          "query": "UnHealthyBackendServers[$window].mean()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "Unhealthy Backends",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "lineInterpolation": "smooth",
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "barAlignment": 0,
            "drawStyle": "line",
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none", "group": "A" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Healthy Backends" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
