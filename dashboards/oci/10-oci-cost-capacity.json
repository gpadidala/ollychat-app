{
  "__inputs": [
    {
      "name": "DS_OCI_METRICS",
      "label": "OCI Metrics",
      "type": "datasource",
      "pluginId": "oci-metrics-datasource"
    },
    {
      "name": "DS_OCI_LOGS",
      "label": "OCI Logs",
      "type": "datasource",
      "pluginId": "oci-logs-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-metrics-datasource",
      "name": "OCI Metrics",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-logs-datasource",
      "name": "OCI Logs",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "id": null,
  "uid": "oci-cost-capacity",
  "title": "OCI Cost & Capacity Planning",
  "description": "Long-range capacity planning dashboard for OCI services including storage growth, compute utilization patterns, database capacity, and network trends over 30-day windows.",
  "tags": ["oci", "cost", "capacity", "planning"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "refresh": "5m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "regions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Region",
        "hide": 0
      },
      {
        "name": "compartment",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "compartments($region)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Compartment",
        "hide": 0
      },
      {
        "name": "window",
        "type": "custom",
        "query": "auto,1m,5m,15m,1h,1d",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Window",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Current Storage & Compute Totals",
      "type": "row"
    },
    {
      "id": 1,
      "title": "Object Storage",
      "description": "Current total bytes stored in OCI Object Storage across all buckets in the selected compartment.",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_objectstorage",
          "query": "StoredBytes[$window].max()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "{{resourceDisplayName}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Block Storage Throughput",
      "description": "Combined read and write throughput for OCI Block Storage volumes in bytes per second.",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_blockstore",
          "query": "VolumeReadThroughput[$window].mean()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "{{resourceDisplayName}} Read",
          "refId": "A"
        },
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_blockstore",
          "query": "VolumeWriteThroughput[$window].mean()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "{{resourceDisplayName}} Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "DB Storage Used",
      "description": "Current storage utilization percentage for OCI Autonomous Database instances. Thresholds: green < 70%, yellow < 85%, red >= 85%.",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_autonomous_database",
          "query": "StorageUtilization[$window].max()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
          "rawQuery": true,
          "legendFormat": "{{resourceDisplayName}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Active Compute Instances",
      "description": "Approximate count of active compute instances derived from the count of CpuUtilization metric data points.",
