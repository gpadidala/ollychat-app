      "type": "row"
    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Total number of network flow log entries. Each flow represents a connection attempt between two endpoints.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
