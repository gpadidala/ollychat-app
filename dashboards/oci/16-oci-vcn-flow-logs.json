        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.logType = 'VCNFlowLog' or data.protocolName != '' | summarize count() as Total"
        }
      ],
      "title": "Total Flows",
      "type": "stat"
    },
