{
  "__inputs": [
    {
      "name": "DS_OCI_METRICS",
      "label": "OCI Metrics",
      "type": "datasource",
      "pluginId": "oci-metrics-datasource"
    },
    {
      "name": "DS_OCI_LOGS",
      "label": "OCI Logs",
      "type": "datasource",
      "pluginId": "oci-logs-datasource"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-metrics-datasource",
      "name": "OCI Metrics",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "oci-logs-datasource",
      "name": "OCI Logs",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "id": null,
  "uid": "oci-security-compliance",
  "title": "OCI Security & Compliance \u2014 Audit Deep Dive",
  "description": "Deep-dive into OCI audit events for security and compliance monitoring. Track IAM activity, failed authentications, policy changes, resource lifecycle events, and potential threat indicators.",
  "tags": ["oci", "security", "compliance", "audit", "deep-dive"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "schemaVersion": 38,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
  },
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "regions()",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Region",
        "hide": 0
      },
      {
        "name": "compartment",
        "type": "query",
        "datasource": "${DS_OCI_METRICS}",
        "query": "compartments($region)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "label": "Compartment",
        "hide": 0
      },
      {
        "name": "window",
        "type": "custom",
        "query": "auto,1m,5m,15m,1h,1d",
        "current": {
          "text": "auto",
          "value": "auto"
        },
        "includeAll": false,
        "multi": false,
        "label": "Window",
        "hide": 0
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Audit Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Total number of audit events across all services in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | summarize count() as Total"
        }
      ],
      "title": "Total Audit Events",
      "type": "stat"
    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Events related to IAM operations: user, group, and policy management.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.eventName =~ 'User|Group|Policy' | summarize count() as IAMEvents"
        }
      ],
      "title": "IAM Events",
      "type": "stat"
    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Failed authentication attempts. Multiple failures may indicate brute-force or credential-stuffing attacks.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.eventName =~ 'AuthFailed' | summarize count() as FailedAuth"
        }
      ],
      "title": "Failed Auth",
      "type": "stat"
    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Policy, rule, and security list changes. Unauthorized policy changes are a critical compliance concern.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          },
          "unit": "short"
