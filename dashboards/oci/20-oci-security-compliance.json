          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.eventName =~ 'Create' | summarize count() as Creates by rounddown(datetime, '1h')"
        },
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "B",
          "region": "$region",
