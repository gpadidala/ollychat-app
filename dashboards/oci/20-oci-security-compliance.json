      ],
      "title": "Policy Changes",
      "type": "stat"
    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Resource creation events across all OCI services.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
