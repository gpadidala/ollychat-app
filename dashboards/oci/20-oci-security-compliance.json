    },
    {
      "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
      "description": "Resource create, update, and delete events stacked by type per hour. Unusual patterns may indicate unauthorized changes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
