      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "oci-logs-datasource", "uid": "${DS_OCI_LOGS}" },
          "maxDataPoints": 10,
          "refId": "A",
          "region": "$region",
          "searchQuery": "search \"\" | where data.eventName =~ 'User|Group|Policy' | summarize count() as IAMEvents by rounddown(datetime, '5m')"
        }
