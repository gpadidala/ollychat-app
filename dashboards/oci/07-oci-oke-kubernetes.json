    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Correlated Logs",
      "type": "row",
      "panels": []
    },
    {
      "id": 9,
      "title": "Container Error Logs",
      "description": "Recent container error logs including OOMKilled, CrashLoopBackOff, and general errors from OCI Logging.",
      "type": "table",
      "datasource": "${DS_OCI_LOGS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": "${DS_OCI_LOGS}",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'error|Error|ERROR|OOMKilled|CrashLoopBackOff' | sort by datetime desc",
          "maxDataPoints": 10,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [],
        "footer": {
          "show": false
        }
      }
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Error Trends from Logs",
      "type": "row",
      "panels": []
    },
    {
      "id": 10,
      "title": "Container Errors Over Time",
      "description": "Trend of container error occurrences aggregated in 5-minute buckets from OCI Logging.",
      "type": "timeseries",
      "datasource": "${DS_OCI_LOGS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "targets": [
        {
          "datasource": "${DS_OCI_LOGS}",
          "region": "$region",
          "searchQuery": "search \"\" | where data.message =~ 'error|Error' | summarize count() by rounddown(datetime, '5m')",
          "maxDataPoints": 10,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
