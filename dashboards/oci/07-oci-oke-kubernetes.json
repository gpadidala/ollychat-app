        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Unschedulable Pods",
      "description": "Number of pods that could not be scheduled. Non-zero values indicate resource constraints or scheduling issues.",
      "type": "stat",
      "datasource": "${DS_OCI_METRICS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "datasource": "${DS_OCI_METRICS}",
          "namespace": "oci_oke",
          "query": "unschedulable_pods[$window].max()",
          "region": "$region",
          "compartmentOCID": "$compartment",
          "tenancymode": "single",
