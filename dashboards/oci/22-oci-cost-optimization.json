      "type": "timeseries",
      "datasource": "${DS_OCI_METRICS}",
      "description": "High volumes may benefit from always-on compute. Compare function costs vs equivalent VM costs at current invocation rates.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
