  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "description": "Breadcrumb navigation showing hierarchy path from L0 to current L3 Kubernetes Debug with lateral links to sibling deep-dive dashboards.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-size:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;\">\n  <a href=\"/d/l2-service-golden-signals/\" style=\"color:#6E9FFF; text-decoration:none;\">&larr; Back to Service</a>\n  <span style=\"color:#aaa;\">|</span>\n  <span style=\"color:#ccc;\"><a href=\"/d/l0-executive-command-center/\" style=\"color:#6E9FFF; text-decoration:none;\">L0</a> &rarr; <a href=\"/d/l1-infrastructure-health/\" style=\"color:#6E9FFF; text-decoration:none;\">L1: Infrastructure</a> &rarr; <a href=\"/d/l2-service-golden-signals/\" style=\"color:#6E9FFF; text-decoration:none;\">L2: $service</a> &rarr; <strong style=\"color:#FF9830;\">L3: K8s Debug</strong></span>\n  <span style=\"color:#aaa;\">|</span>\n  <a href=\"/d/l3-trace-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Traces]</a>\n  <a href=\"/d/l3-log-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Logs]</a>\n  <a href=\"/d/l3-profile-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Profiles]</a>\n</div>"
      },
      "datasource": {
        "type": "datasource",
        "uid": "grafana"
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Pod Status",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pod Phase",
      "description": "Current phase of the selected pod. Green indicates Running; red indicates the pod is not in a Running state and needs investigation.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_pod_status_phase{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", phase=\"Running\"}",
          "legendFormat": "Pod Phase",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "Running",
                  "color": "green"
                },
                "0": {
                  "text": "Not Running",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Container Restarts",
      "description": "Total container restart count for the selected pod. More than 3 restarts signals instability; above 10 is a CrashLoopBackOff risk.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_pod_container_status_restarts_total{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"})",
          "legendFormat": "Restarts",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pod Age",
      "description": "Time since the pod was started. Very young pods may have recently restarted. Very old pods may need rolling updates.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - kube_pod_start_time{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"}",
          "legendFormat": "Pod Age",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Ready Containers",
      "description": "Ratio of ready containers to total containers in the pod. All containers should be ready for the pod to serve traffic.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_pod_container_status_ready{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"}) / count(kube_pod_container_info{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"})",
          "legendFormat": "Ready Ratio",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Pod Resources",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pod CPU",
      "description": "CPU usage, requests, and limits for the selected pod. Usage consistently near limits indicates the pod needs more CPU or is being throttled.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", container!=\"\"}[$__rate_interval]))",
          "legendFormat": "Usage"
        },
        {
          "refId": "B",
          "expr": "sum(kube_pod_container_resource_requests{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", resource=\"cpu\"})",
          "legendFormat": "Requests"
        },
        {
          "refId": "C",
          "expr": "sum(kube_pod_container_resource_limits{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", resource=\"cpu\"})",
          "legendFormat": "Limits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "cores",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Requests"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [10, 10]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Limits"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [10, 10]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pod Memory",
      "description": "Working set memory usage, requests, and limits for the selected pod. Memory near limits risks OOMKill events.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(container_memory_working_set_bytes{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", container!=\"\"})",
          "legendFormat": "Usage"
        },
        {
          "refId": "B",
          "expr": "sum(kube_pod_container_resource_requests{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", resource=\"memory\"})",
          "legendFormat": "Requests"
        },
        {
          "refId": "C",
          "expr": "sum(kube_pod_container_resource_limits{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\", resource=\"memory\"})",
          "legendFormat": "Limits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Requests"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [10, 10]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Limits"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [10, 10]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Pod Network",
      "description": "Network receive and transmit bytes per second for the selected pod. Asymmetric traffic patterns may indicate data pipeline issues.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_network_receive_bytes_total{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "Rx bytes/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(container_network_transmit_bytes_total{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "Tx bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Rx bytes/s"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Tx bytes/s"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Container Restart Timeline",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Restart Timeline",
      "description": "Container restart events over time shown as bars. Each bar represents restarts within a 5-minute window. Clusters of restarts indicate CrashLoopBackOff patterns.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "changes(kube_pod_container_status_restarts_total{pod=\"$pod\", namespace=~\"$namespace\", cluster=~\"$cluster\"}[5m])",
          "legendFormat": "{{container}} restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "restarts",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Kubernetes Events",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "logs",
      "title": "K8s Events",
      "description": "Kubernetes events and logs mentioning the selected pod. Includes scheduling decisions, image pulls, readiness probe failures, and OOMKill events.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{cluster=~\"$cluster\", namespace=~\"$namespace\"} |= \"$pod\" | logfmt",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      }
    },
    {
      "id": 104,
      "type": "row",
      "title": "Node Metrics",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Node CPU",
      "description": "CPU utilization of the node hosting the selected pod. High node CPU may cause throttling even if pod limits are not reached.",
