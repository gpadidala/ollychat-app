      "title": "L3: K8s Debug",
      "tooltip": "L3 Kubernetes Debug",
      "type": "link",
      "url": "/d/l3-kubernetes-debug/"
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "description": "Breadcrumb navigation showing hierarchy path from L0 to current L3 Profile Explorer with lateral links to sibling deep-dive dashboards.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-size:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;\">\n  <a href=\"/d/l2-service-golden-signals/\" style=\"color:#6E9FFF; text-decoration:none;\">&larr; Back to Service</a>\n  <span style=\"color:#aaa;\">|</span>\n  <span style=\"color:#ccc;\"><a href=\"/d/l0-executive-command-center/\" style=\"color:#6E9FFF; text-decoration:none;\">L0</a> &rarr; <a href=\"/d/l1-application-performance/\" style=\"color:#6E9FFF; text-decoration:none;\">L1</a> &rarr; <a href=\"/d/l2-service-golden-signals/\" style=\"color:#6E9FFF; text-decoration:none;\">L2: $service</a> &rarr; <strong style=\"color:#FF9830;\">L3: Profiles</strong></span>\n  <span style=\"color:#aaa;\">|</span>\n  <a href=\"/d/l3-trace-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Traces]</a>\n  <a href=\"/d/l3-log-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Logs]</a>\n  <a href=\"/d/l3-kubernetes-debug/\" style=\"color:#6E9FFF; text-decoration:none;\">[K8s Debug]</a>\n</div>"
      },
      "datasource": {
        "type": "datasource",
        "uid": "grafana"
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "CPU Profiling",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "flamegraph",
      "title": "CPU Flame Graph",
      "description": "CPU time flame graph from Pyroscope continuous profiling. Wider bars indicate functions consuming more CPU. Use this to identify hot code paths and optimization targets.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "$datasource_pyroscope"
      },
      "targets": [
        {
          "refId": "A",
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"$service\"}",
          "queryType": "profile"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "Memory Profiling",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "panels": []
    },
    {
      "id": 3,
      "type": "flamegraph",
      "title": "Memory Flame Graph",
      "description": "Memory allocation flame graph from Pyroscope. Shows where memory is being allocated. Persistent wide bars may indicate memory leaks or excessive allocation patterns.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "$datasource_pyroscope"
      },
      "targets": [
        {
          "refId": "A",
          "profileTypeId": "memory:alloc_objects:count:space:bytes",
          "labelSelector": "{service_name=\"$service\"}",
          "queryType": "profile"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "Resource Context",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CPU Usage by Pod",
      "description": "Actual CPU usage per pod from container metrics. Compare with flame graph data to correlate profiling hotspots with real resource consumption.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", pod=~\"$service.*\", cluster=~\"$cluster\"}[$__rate_interval]))",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "cores",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory Usage by Pod",
      "description": "Working set memory per pod. Sustained growth patterns visible here should be cross-referenced with the memory flame graph to identify leaking allocations.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\", pod=~\"$service.*\", cluster=~\"$cluster\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": {
              "mode": "none",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "Goroutine / Mutex",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "panels": []
    },
    {
      "id": 6,
      "type": "flamegraph",
      "title": "Goroutine Profile",
      "description": "Goroutine flame graph showing active goroutine stacks. High goroutine counts in specific call paths may indicate goroutine leaks or blocking operations.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 37
      },
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "$datasource_pyroscope"
      },
      "targets": [
        {
          "refId": "A",
          "profileTypeId": "goroutine:goroutines:count:goroutine:count",
          "labelSelector": "{service_name=\"$service\"}",
          "queryType": "profile"
        }
      ]
    },
    {
      "id": 7,
      "type": "flamegraph",
      "title": "Mutex Profile",
      "description": "Mutex contention flame graph showing lock contention hotspots. Wide bars indicate functions where threads spend significant time waiting on locks.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 37
      },
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "$datasource_pyroscope"
      },
      "targets": [
        {
          "refId": "A",
          "profileTypeId": "mutex:contentions:count:delay:nanoseconds",
          "labelSelector": "{service_name=\"$service\"}",
          "queryType": "profile"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["level:L3", "profiling", "pyroscope", "debug"],
