  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "description": "Breadcrumb navigation showing hierarchy path from L0 to current L3 Log Explorer with lateral links to sibling deep-dive dashboards.",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-size:14px; display:flex; align-items:center; gap:16px; flex-wrap:wrap;\">\n  <a href=\"/d/l2-service-golden-signals/\" style=\"color:#6E9FFF; text-decoration:none;\">&larr; Back to Service</a>\n  <span style=\"color:#aaa;\">|</span>\n  <span style=\"color:#ccc;\"><a href=\"/d/l0-executive-command-center/\" style=\"color:#6E9FFF; text-decoration:none;\">L0</a> &rarr; <a href=\"/d/l1-application-performance/\" style=\"color:#6E9FFF; text-decoration:none;\">L1</a> &rarr; <a href=\"/d/l2-service-golden-signals/\" style=\"color:#6E9FFF; text-decoration:none;\">L2: $service</a> &rarr; <strong style=\"color:#FF9830;\">L3: Logs</strong></span>\n  <span style=\"color:#aaa;\">|</span>\n  <a href=\"/d/l3-trace-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Traces]</a>\n  <a href=\"/d/l3-profile-explorer/\" style=\"color:#6E9FFF; text-decoration:none;\">[Profiles]</a>\n  <a href=\"/d/l3-kubernetes-debug/\" style=\"color:#6E9FFF; text-decoration:none;\">[K8s Debug]</a>\n</div>"
      },
      "datasource": {
        "type": "datasource",
        "uid": "grafana"
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Log Volume Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Log Volume/s",
      "description": "Total log lines per second across all levels for the selected service. Sudden spikes may indicate noisy debug logging or error storms.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"}[$__auto]))",
          "legendFormat": "Total Logs/s",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Logs/s",
      "description": "Rate of error-level log lines. Values above 10/s indicate a significant error condition that needs immediate attention.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt | level = \"error\" [$__auto]))",
          "legendFormat": "Error Logs/s",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Warning Logs/s",
      "description": "Rate of warning-level log lines. Elevated warnings often precede error escalations and should be monitored proactively.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt | level = \"warn\" [$__auto]))",
          "legendFormat": "Warning Logs/s",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "orange", "value": 20 }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Error / Total Ratio",
      "description": "Percentage of log lines at error level. Above 5% signals systemic issues; above 15% indicates a critical failure condition.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 3
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt | level = \"error\" [$__auto])) / (sum(count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"}[$__auto])) + 0.001) * 100",
          "legendFormat": "Error Ratio %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "Log Volume Trends",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Log Volume by Level",
      "description": "Stacked area chart of log volume broken down by level (error, warn, info, debug). Helps identify log storms and level distribution shifts over time.",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (level) (count_over_time({cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt [$__auto]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "axisPlacement": "auto",
            "axisLabel": "logs/s",
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#EAB839"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "gray"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["min", "max", "mean", "lastNotNull"]
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Log Stream",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "panels": []
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Error & Warning Logs",
      "description": "Filtered error and warning log stream. Click log line to view full context. Extract traceID fields for trace correlation.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt | level =~ \"error|warn\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "All Logs",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Full Log Stream",
      "description": "Unfiltered log stream for the selected service. Use LogQL pipeline stages in the query editor above to filter, parse, and extract fields interactively.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "loki",
        "uid": "$datasource_loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{cluster=~\"$cluster\", namespace=~\"$namespace\", job=~\"$service.*\"} | logfmt",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "prettifyLogMessage": false
      }
    }
