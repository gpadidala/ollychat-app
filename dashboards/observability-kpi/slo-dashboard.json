      "targetBlank": false,
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "SLO Summary",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "Current availability SLI: percentage of non-5xx requests over the dashboard time range. Compare against the configured SLO target.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 3,
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(1 - (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[$__rate_interval])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001))) * 100",
          "legendFormat": "Availability",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Availability SLO",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "Percentage of requests served under the latency threshold. A latency SLI measures the proportion of sufficiently fast requests.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 5,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_request_duration_seconds_bucket{job=\"$app\", namespace=~\"$namespace\", le=\"$latency_threshold\"}[$__rate_interval])) / (sum(rate(http_request_duration_seconds_count{job=\"$app\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001) * 100",
          "legendFormat": "Latency SLI",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Latency SLO",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "Remaining error budget as a percentage. When this reaches 0%, the SLO is breached. Calculated as: (SLO - actual_error_rate) / allowed_error_rate * 100.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 10,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "clamp_min((($slo_target / 100 - (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[$__rate_interval])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[$__rate_interval])) + 0.001))) / (1 - $slo_target / 100)) * 100, 0)",
          "legendFormat": "Budget Remaining",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Error Budget Remaining %",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "How fast the error budget is being consumed relative to a sustainable rate. 1x = budget consumed evenly over the window. >2x = accelerated consumption, investigate. >10x = critical, page.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "x"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 15,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[1h])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[1h])) + 0.001)) / (1 - $slo_target / 100)",
          "legendFormat": "Burn Rate (1h)",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Error Budget Burn Rate (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "Estimated hours until the error budget is fully exhausted at the current 1h burn rate. Lower values require faster response.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 1,
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": {
                  "text": "N/A"
                }
              },
              "type": "special"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 24
              },
              {
                "color": "green",
                "value": 168
              }
            ]
          },
          "unit": "h"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "clamp_min(($slo_target / 100 - (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[1h])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[1h])) + 0.001))) / ((sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[1h])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[1h])) + 0.001)) + 0.0001) * 720, 0)",
          "legendFormat": "Hours Left",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Time Until Budget Exhaustion",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 101,
      "title": "SLO Compliance Trend",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "Availability SLI plotted over time with the SLO target as a threshold line. Dips below the line represent SLO violations for that window.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Availability %",
            "axisPlacement": "auto",
            "axisSoftMax": 100.1,
            "axisSoftMin": 97.9,
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "line+area",
              "value": 99.9
            }
          },
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "transparent",
                "value": 99.9
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Availability SLI"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "super-light-green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "min",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(1 - (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[5m])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[5m])) + 0.001))) * 100",
          "legendFormat": "Availability SLI",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Availability SLI Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 102,
      "title": "Multi-Window Burn Rate (Google SRE)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_mimir}"
      },
      "description": "Multi-window burn rate analysis per Google SRE methodology. Short windows (5m, 1h) catch fast-burning incidents; long windows (6h, 24h) catch slow-burning degradation. Threshold lines: 1x = sustainable, 2x = concerning, 10x = page-worthy.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Burn Rate (x)",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "line",
              "value": 1
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "x"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "5m burn rate"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF4757",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "1h burn rate"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FFB020",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "6h burn rate"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#6C63FF",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "24h burn rate"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#00C48C",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "10.4.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[5m])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[5m])) + 0.001)) / (1 - $slo_target / 100)",
          "legendFormat": "5m burn rate",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[1h])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[1h])) + 0.001)) / (1 - $slo_target / 100)",
          "legendFormat": "1h burn rate",
          "range": true,
          "refId": "B",
          "hide": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[6h])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[6h])) + 0.001)) / (1 - $slo_target / 100)",
          "legendFormat": "6h burn rate",
          "range": true,
          "refId": "C",
          "hide": false
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_mimir}"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\", status=~\"5..\"}[24h])) / (sum(rate(http_requests_total{job=\"$app\", namespace=~\"$namespace\"}[24h])) + 0.001)) / (1 - $slo_target / 100)",
          "legendFormat": "24h burn rate",
          "range": true,
          "refId": "D",
          "hide": false
        }
      ],
      "title": "Multi-Window Error Budget Burn Rate",
      "type": "timeseries"
    },
    {
