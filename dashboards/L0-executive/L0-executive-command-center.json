    {
      "id": 1,
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "transparent": true,
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex; align-items:center; gap:0; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.08);\">\n  <div style=\"display:flex; gap:0;\">\n    <a style=\"padding:8px 20px; background:rgba(64,196,255,0.15); color:#4FC3F7; font-weight:700; font-size:13px; text-decoration:none; border-bottom:2px solid #4FC3F7; letter-spacing:0.3px;\">Command Center</a>\n    <a href=\"/d/l1-infrastructure-overview/l1-infrastructure-overview\" style=\"padding:8px 20px; color:#999; font-size:13px; text-decoration:none; border-bottom:2px solid transparent; letter-spacing:0.3px;\">Infrastructure</a>\n    <a href=\"/d/l1-application-performance/l1-application-performance\" style=\"padding:8px 20px; color:#999; font-size:13px; text-decoration:none; border-bottom:2px solid transparent; letter-spacing:0.3px;\">Applications</a>\n    <a href=\"/d/l1-profiling-overview/l1-profiling-overview\" style=\"padding:8px 20px; color:#999; font-size:13px; text-decoration:none; border-bottom:2px solid transparent; letter-spacing:0.3px;\">Profiling</a>\n  </div>\n  <div style=\"margin-left:auto; text-align:right; padding-right:8px;\">\n    <span style=\"font-size:11px; color:#666; text-transform:uppercase; letter-spacing:1px;\">L0: Command Center</span><br/>\n    <span style=\"font-size:12px; color:#4FC3F7; font-weight:500;\">Live &bull; Auto-Refresh 1m</span>\n  </div>\n</div>",
        "code": { "language": "html", "showLineNumbers": false, "showMiniMap": false }
      },
      "pluginVersion": "11.6.4"
    },
    {
      "id": 100,
      "title": "Platform Health at a Glance",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "panels": []
    },
    {
      "id": 2,
      "title": "Overall Platform Health",
      "description": "Composite platform health score based on component availability. Green >95%, Amber 80-95%, Red <80%.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "(sum(up{cluster=~\"$cluster\", stack=~\"$stack\"}) / count(up{cluster=~\"$cluster\", stack=~\"$stack\"})) * 100",
          "legendFormat": "Health",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4757", "value": null },
              { "color": "#FFB020", "value": 80 },
              { "color": "#00C48C", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "Drill into Infrastructure",
          "url": "/d/l1-infrastructure-overview/l1-infrastructure-overview?var-cluster=$cluster&var-stack=$stack&from=$__from&to=$__to"
        }
      ],
      "pluginVersion": "11.6.4"
    },
    {
      "id": 3,
      "title": "Active Incidents",
      "description": "Count of currently firing alerts across all clusters. Any P1 incident triggers red status.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "count(ALERTS{alertstate=\"firing\", cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Firing Alerts",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00C48C", "value": null },
              { "color": "#FFB020", "value": 1 },
              { "color": "#FF4757", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "pluginVersion": "11.6.4"
    },
    {
      "id": 4,
      "title": "SLO Attainment (30d)",
      "description": "Platform-wide SLO attainment based on non-5xx request ratio.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "(1 - (sum(rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) / (sum(rate(http_requests_total{cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) + 0.001))) * 100",
          "legendFormat": "SLO %",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4757", "value": null },
              { "color": "#FFB020", "value": 99 },
              { "color": "#00C48C", "value": 99.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "links": [
        {
          "title": "Drill into Application Performance",
          "url": "/d/l1-application-performance/l1-application-performance?var-cluster=$cluster&var-stack=$stack&from=$__from&to=$__to"
        }
      ],
      "pluginVersion": "11.6.4"
    },
    {
      "id": 5,
      "title": "Error Budget Remaining",
      "description": "Remaining error budget against 99.9% SLO target. When this reaches 0%, freeze all deployments.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "((1 - (sum(rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) / (sum(rate(http_requests_total{cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) + 0.001))) - 0.999) / 0.001 * 100",
          "legendFormat": "Budget %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF4757", "value": null },
              { "color": "#FFB020", "value": 20 },
              { "color": "#00C48C", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "pluginVersion": "11.6.4"
    },
    {
      "id": 6,
      "title": "Request Volume",
      "description": "Global request throughput across all services.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00C48C", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "pluginVersion": "11.6.4"
    },
    {
      "id": 7,
      "title": "P99 Latency (Global)",
      "description": "99th percentile request latency across all services.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00C48C", "value": null },
              { "color": "#FFB020", "value": 0.5 },
              { "color": "#FF4757", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "justifyMode": "auto",
        "orientation": "auto"
      },
      "pluginVersion": "11.6.4"
    },
    {
      "id": 101,
      "title": "Traffic & Error Trends",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "panels": []
    },
    {
      "id": 8,
      "title": "Request Rate & Error Rate (24h)",
      "description": "Platform-wide request and error rate trends with deployment annotations.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 15, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval]))",
          "legendFormat": "Total Requests/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "sum(rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval]))",
          "legendFormat": "5xx Errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            },
            "axisPlacement": "auto",
            "axisBorderShow": false,
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "5xx Errors/s"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF4757",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "pluginVersion": "11.6.4"
    },
    {
      "id": 9,
      "title": "Top 5 Components by Error Rate",
      "description": "Top 5 services ranked by 5xx error percentage. Click a service to drill into its golden signals.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "expr": "topk(5, sum by (job) (rate(http_requests_total{status=~\"5..\", cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) / (sum by (job) (rate(http_requests_total{cluster=~\"$cluster\", stack=~\"$stack\"}[$__rate_interval])) + 0.001) * 100)",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#00C48C", "value": null },
              { "color": "#FFB020", "value": 1 },
              { "color": "#FF4757", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "links": [
        {
          "title": "View Service Detail",
          "url": "/d/l2-service-golden-signals/l2-service-golden-signals?var-service=${__field.labels.job}&from=$__from&to=$__to"
        }
      ],
      "pluginVersion": "11.6.4"
    },
