        "enable": true,
        "expr": "changes(process_start_time_seconds{cluster=~\"$cluster\", stack=~\"$stack\"}[5m]) > 0",
        "hide": false,
        "iconColor": "#FFA500",
        "name": "Component Restarts",
        "step": "60s",
        "tagKeys": "cluster,stack",
        "titleFormat": "Restart: {{pod}}",
        "type": "tags"
      }
