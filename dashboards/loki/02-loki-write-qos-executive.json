      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(rate(loki_write_request_duration_seconds_bucket{le=\"0.5\"}[30m])) / sum(rate(loki_write_request_duration_seconds_bucket{le=\"+Inf\"}[30m])) * 100",
