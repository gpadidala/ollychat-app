          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(grafana_http_request_duration_seconds_bucket{handler=~\"/api/datasources/proxy/.*\"}[5m])) by (le))",
          "legendFormat": "P95 Latency",
          "range": true,
          "refId": "A"
