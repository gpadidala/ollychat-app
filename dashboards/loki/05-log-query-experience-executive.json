      "id": 99,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "### Methodology Note\nThis dashboard measures log query experience from the **Grafana proxy perspective** — the actual latency users experience when running queries. Loki does not expose internal read-path latency buckets, so **Grafana HTTP proxy metrics** (`grafana_http_request_duration_seconds_bucket`) serve as the ground truth for user experience.",
        "mode": "markdown"
      },
      "pluginVersion": "11.0.0",
      "transparent": true,
      "title": "",
      "type": "text"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "id": 101,
      "panels": [],
      "title": "Executive Summary",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Percentage of log queries completing within the 2.0s SLO target over the last 30 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(rate(grafana_http_request_duration_seconds_bucket{handler=~\"/api/datasources/proxy/.*\", le=\"2.0\"}[30m])) / sum(rate(grafana_http_request_duration_seconds_bucket{handler=~\"/api/datasources/proxy/.*\", le=\"+Inf\"}[30m])) * 100",
          "legendFormat": "QoS Score",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Log Query QoS Score",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Service Level Objective: 95% of log queries must complete within 2.0 seconds.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
